<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= question.title %> | StudyGlade</title>
  <meta name="description" content="<%= question.description.substring(0, 160) %>">
  <link rel="canonical" href="https://studyglade.com/question/<%= question._id %>">
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/index.css">
</head>
<body>
  <header>
    <nav class="navbar"><!-- same navbar --></nav>
  </header>
  <main>
    <div class="container">
      <h1><%= question.title %></h1>
      <div class="question-meta">
        <span><i class="fas fa-tag"></i> <%= subject %></span>
        <span><i class="fas fa-dollar-sign"></i> $<%= budget %></span>
        <span><i class="fas fa-calendar"></i> Asked <%= new Date(createdAt).toLocaleDateString() %></span>
      </div>
      <p><strong>Description:</strong> <%= question.description %></p>

      <% if (status === 'completed' && tutorName) { %>
        <div class="tutor-info">
          <h3>Answered by <%= tutorName %></h3>
          <div class="rating"><%= tutorRating?.toFixed(1) || 'New' %> ⭐</div>
        </div>
        <div class="answer-section">
          <p>This question has been answered. <a href="/login?returnTo=/question/<%= question._id %>">Log in</a> to view or download the answer.</p>
        </div>
      <% } else { %>
        <p>This question is still open. <a href="/login?returnTo=/question/<%= question._id %>">Log in</a> to place a bid or get help.</p>
      <% } %>
    </div>
  </main>
  <footer class="premium-footer"></footer>
</body>
</html>