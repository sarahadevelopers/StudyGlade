<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= subject %> Homework Help & Tutors | StudyGlade</title>
  <meta name="description" content="Get <%= subject %> homework help from expert tutors. Access study resources, solved questions, and 24/7 academic support. Post your question and get answers fast.">
  <meta name="keywords" content="<%= subject %> homework help, <%= subject %> tutors, <%= subject %> study resources, online tutoring <%= subject.toLowerCase() %>">
  <link rel="canonical" href="https://studyglade.com/subjects/<%= slug %>">
  <meta property="og:title" content="<%= subject %> Homework Help & Expert Tutors | StudyGlade">
  <meta property="og:description" content="Find top-rated <%= subject %> tutors, study documents, and solved questions. Get help 24/7 and improve your grades.">
  <meta property="og:image" content="https://studyglade.com/og-logo.png">
  <meta property="og:url" content="https://studyglade.com/subjects/<%= slug %>">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/index.css">
  
  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studyglade.com/" },
      { "@type": "ListItem", "position": 2, "name": "All Subjects", "item": "https://studyglade.com/subjects" },
      { "@type": "ListItem", "position": 3, "name": "<%= subject %>", "item": "https://studyglade.com/subjects/<%= slug %>" }
    ]
  }
  </script>
  
  <!-- WebPage Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "<%= subject %> Homework Help",
    "description": "Access <%= subject %> tutoring, study guides, and solved questions.",
    "url": "https://studyglade.com/subjects/<%= slug %>",
    "isPartOf": { "@type": "WebSite", "name": "StudyGlade", "url": "https://studyglade.com/" }
  }
  </script>
  
  <style>
    /* Additional styles for consistency (you can move to index.css later) */
    .breadcrumb-nav { margin-bottom: 1rem; font-size: 0.8rem; }
    .breadcrumb-nav ul { list-style: none; display: flex; gap: 0.5rem; flex-wrap: wrap; padding: 0; margin: 1rem 0; }
    .breadcrumb-nav li { display: inline-flex; align-items: center; gap: 0.3rem; }
    .breadcrumb-nav li:not(:last-child)::after { content: "›"; color: var(--slate); }
    .breadcrumb-nav a { text-decoration: none; color: var(--brand-blue); }
    .tutor-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.2rem; margin: 1.5rem 0; }
    .tutor-card { background: white; border-radius: 24px; padding: 1rem; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.04); transition: transform 0.2s; }
    .tutor-card:hover { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(0,0,0,0.08); }
    .tutor-card img { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; margin-bottom: 0.5rem; }
    .tutor-card h3 { font-size: 1.1rem; margin: 0.3rem 0; }
    .document-list { margin: 1.5rem 0; }
    .document-item { display: flex; justify-content: space-between; align-items: center; padding: 0.8rem 0; border-bottom: 1px solid #eee; }
    .question-list { list-style: none; padding: 0; }
    .question-list li { margin: 0.5rem 0; }
    .question-list a { text-decoration: none; color: var(--text-navy); display: block; padding: 0.5rem; border-bottom: 1px solid #f0f0f0; }
    .question-list a:hover { color: var(--brand-blue); }
    .cta-box { background: var(--pale-blue); padding: 1.5rem; border-radius: 24px; text-align: center; margin: 2rem 0; }
    .cta-box a { font-weight: 600; }
    .related-subjects { margin: 2rem 0; text-align: center; }
    .related-subjects a { background: var(--pale-blue); padding: 0.3rem 0.8rem; border-radius: 40px; margin: 0.2rem; display: inline-block; text-decoration: none; color: var(--brand-blue); }
  </style>
</head>
<body>

<header>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">StudyGlade<i class="fas fa-pen-fancy"></i></a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/document-library.html">Library</a>
        <a href="/subjects">Subjects</a>
        <a href="/pricing">Pricing</a>
      </div>
      <div class="nav-buttons">
        <a href="/login.html" class="btn btn-outline-white">Login</a>
        <a href="/register.html" class="btn btn-primary">Sign Up</a>
      </div>
    </div>
  </nav>
</header>

<main>
  <div class="container">
    <!-- Breadcrumb UI -->
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/subjects">All Subjects</a></li>
        <li><span><%= subject %></span></li>
      </ul>
    </nav>

    <h1><%= subject %> Homework Help & Online Tutors</h1>
    <p>Find expert tutors, study resources, and answers to <%= subject %> questions. Post your own question and get help within hours.</p>

    <!-- Tutors Section -->
    <section>
      <h2>Top Tutors for <%= subject %></h2>
      <% if (tutors && tutors.length) { %>
        <div class="tutor-grid">
          <% tutors.forEach(t => { %>
            <div class="tutor-card">
              <img src="<%= t.avatar || 'https://randomuser.me/api/portraits/lego/1.jpg' %>" alt="<%= t.fullName %>" width="80" height="80" loading="lazy">
              <h3><%= t.fullName %></h3>
              <div class="rating"><i class="fas fa-star"></i> <%= t.tutorProfile?.rating?.toFixed(1) || 'New' %> (<%= t.tutorProfile?.completedQuestions || 0 %> lessons)</div>
              <a href="/tutor/<%= t._id %>" class="btn-sm btn-primary-sm" style="margin-top: 0.5rem; display: inline-block;">View Profile</a>
            </div>
          <% }) %>
        </div>
        <p><a href="/tutor/"><strong>All Tutors</strong></a> →</p>
      <% } else { %>
        <p>No tutors listed yet for <%= subject %>. <a href="/become-tutor">Become a tutor</a> and help students.</p>
      <% } %>
    </section>

    <!-- Documents Section -->
    <section>
      <h2>Popular <%= subject %> Documents</h2>
      <% if (documents && documents.length) { %>
        <div class="document-list">
          <% documents.forEach(d => { %>
            <div class="document-item">
              <a href="/document/<%= d.slug %>" class="document-title-link"><%= d.title %></a>
              <span class="price">$<%= d.price %></span>
            </div>
          <% }) %>
        </div>
        <p><a href="/document-library.html?subject=<%= encodeURIComponent(subject) %>">Browse all <%= subject %> documents</a> →</p>
      <% } else { %>
        <p>No documents yet. Check back later or <a href="/upload-document.html">upload your own</a>.</p>
      <% } %>
    </section>

    <!-- Questions Section -->
    <section>
      <h2>Recent <%= subject %> Questions</h2>
      <% if (questions && questions.length) { %>
        <ul class="question-list">
          <% questions.forEach(q => { %>
            <li><a href="/question/<%= q._id %>"><%= q.title %></a></li>
          <% }) %>
        </ul>
        <p><a href="/questions?subject=<%= encodeURIComponent(subject) %>">See all <%= subject %> questions</a> →</p>
      <% } else { %>
        <p>No questions yet. <a href="/post-question.html">Ask a question</a> to get help from tutors.</p>
      <% } %>
    </section>

    <!-- Related Subjects (dynamic from common fields) -->
    <div class="related-subjects">
      <h3>Other Subjects You May Like</h3>
      <div>
        <% const related = ['Mathematics', 'Statistics', 'Nursing', 'Engineering', 'Computer Science']; 
           related.forEach(rel => { if (rel !== subject) { %>
          <a href="/subjects/<%= rel.toLowerCase().replace(/ /g, '-') %>"><%= rel %></a>
        <% } }); %>
        <a href="/subjects">All Subjects</a>
      </div>
    </div>

    <!-- Call to Action -->
    <div class="cta-box">
      <p>📚 Need help with <%= subject %>? <a href="/post-question.html">Post your question now</a> and get instant bids from expert tutors. 24/7 support – start improving your grades today!</p>
    </div>
  </div>
</main>

<footer class="premium-footer">
  <div class="footer-container">
    <div class="footer-brand">
      <div class="footer-logo-wrapper"><a href="/" class="footer-logo">StudyGlade<i class="fas fa-pen-fancy"></i></a></div>
      <p class="brand-description">Empowering students worldwide with expert academic help, quality resources, and a supportive learning community.</p>
      <div class="newsletter-box"><h5>Stay Updated</h5><form class="newsletter-form"><input type="email" placeholder="Enter your email" required><button type="submit">Join</button></form><p class="newsletter-note">Join 10k+ students. No spam, ever.</p></div>
      <div class="social-links"><a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a><a href="#" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a><a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a><a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a><a href="#" aria-label="TikTok"><i class="fab fa-tiktok"></i></a><a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a></div>
    </div>
    <div class="footer-links-grid">
      <div class="link-column"><h4>Platform</h4><ul><li><a href="/post-question">Post a Question</a></li><li><a href="/document-library.html">Browse Documents</a></li><li><a href="/find-tutors">Find a Tutor</a></li><li><a href="/online-classroom">Online Classroom</a></li><li><a href="/study-library">Study Library</a></li><li><a href="/calendar">Calendar</a></li></ul></div>
      <div class="link-column"><h4>Resources</h4><ul>
        <li><a href="/study-materials">Study Materials</a></li>
        <li><a href="/research-papers">Research Papers</a></li>
        <li><a href="/practice-tests">Practice Tests</a></li>
        <li><a href="/subject-guides">Subject Guides</a></li>
        <li><a href="/academic-tools">Academic Tools</a></li>
        <li><a href="/free-resources">Free Resources</a></li>
        <li><a href="/questions"><strong>All Solved Questions</strong></a></li>
        <li><a href="/subjects"><strong>All Subjects</strong></a></li>
        <li><a href="/tutor/"><strong>All Tutors</strong></a></li>
      </ul></div>
      <div class="link-column"><h4>Support</h4><ul><li><a href="/help">Help Centre</a></li><li><a href="/contact">Contact Us</a></li><li><a href="/live-chat">Live Chat</a></li><li><a href="/how-it-works">How It Works</a></li><li><a href="/tutor-support">Tutor Support</a></li><li><a href="/feedback">Feedback</a></li></ul></div>
      <div class="link-column"><h4>Legal</h4><ul><li><a href="/privacy">Privacy Policy</a></li><li><a href="/terms">Terms of Service</a></li><li><a href="/refund">Refund Policy</a></li><li><a href="/cookies">Cookie Policy</a></li><li><a href="/honor-code">Honor Code</a></li></ul></div>
      <div class="link-column"><h4>About Us</h4><ul><li><a href="/about">About StudyGlade</a></li><li><a href="/careers">Careers</a></li><li><a href="/press">Press & Media</a></li><li><a href="/blog">Blog</a></li><li><a href="/partnerships">Partnerships</a></li></ul></div>
    </div>
  </div>
  <div class="footer-bottom"><p>© <span id="year"></span> StudyGlade. All rights reserved.</p><button class="back-to-top" id="backToTopBtn"><i class="fas fa-arrow-up"></i> Top</button></div>
</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();
  const backToTopBtn = document.getElementById('backToTopBtn');
  if (backToTopBtn) backToTopBtn.addEventListener('click', (e) => { e.preventDefault(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
</script>
</body>
</html>