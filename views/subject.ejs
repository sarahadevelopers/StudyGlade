<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= subject %> Homework Help & Tutors | StudyGlade</title>
  <meta name="description" content="Get <%= subject %> homework help from expert tutors. Access study resources, solved questions, and 24/7 academic support. Post your question and get answers fast.">
  <meta name="keywords" content="<%= subject %> homework help, <%= subject %> tutors, <%= subject %> study resources, online tutoring <%= subject.toLowerCase() %>">
  <link rel="canonical" href="https://studyglade.com/subjects/<%= slug %>">
  <meta property="og:title" content="<%= subject %> Homework Help & Expert Tutors | StudyGlade">
  <meta property="og:description" content="Find top-rated <%= subject %> tutors, study documents, and solved questions. Get help 24/7 and improve your grades.">
  <meta property="og:image" content="https://studyglade.com/og-logo.png">
  <meta property="og:url" content="https://studyglade.com/subjects/<%= slug %>">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/webp" href="images/studyglade-pen-favicon.webp">
  <link rel="icon" type="image/png" href="images/studyglade-pen-favicon.png" sizes="32x32">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/index.css">
  
  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studyglade.com/" },
      { "@type": "ListItem", "position": 2, "name": "All Subjects", "item": "https://studyglade.com/subjects" },
      { "@type": "ListItem", "position": 3, "name": "<%= subject %>", "item": "https://studyglade.com/subjects/<%= slug %>" }
    ]
  }
  </script>
  
  <!-- WebPage Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "<%= subject %> Homework Help",
    "description": "Access <%= subject %> tutoring, study guides, and solved questions.",
    "url": "https://studyglade.com/subjects/<%= slug %>",
    "isPartOf": { "@type": "WebSite", "name": "StudyGlade", "url": "https://studyglade.com/" }
  }
  </script>
  
  <style>
    /* ---------- Premium Design System (matching homepage & subjects index) ---------- */
    :root {
      --navy: #061B49;
      --deep-blue: #0B2E75;
      --brand-blue: #005BFF;
      --royal-blue: #2563EB;
      --sky-blue: #38BDF8;
      --ice-blue: #EFF6FF;
      --pale-blue: #DBEAFE;
      --white: #FFFFFF;
      --text-navy: #0F172A;
      --slate: #64748B;
      --border-grey: #E2E8F0;
      --success: #10B981;
      --warning: #F59E0B;
      --error: #EF4444;
      --shadow-sm: 0 4px 10px -2px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.02);
      --shadow-md: 0 10px 20px -5px rgba(0,0,0,0.08);
      --grad-primary: linear-gradient(135deg, #005BFF 0%, #2563EB 60%, #38BDF8 100%);
    }

    /* Glass‑morphism navbar */
    .navbar {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(226, 232, 240, 0.6);
      padding: 0.75rem 0;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    .navbar .container {
      width: min(1200px, 92%);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--text-navy);
      text-decoration: none;
    }
    .logo i {
      color: var(--brand-blue);
      font-size: 1.6rem;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }
    .nav-links a {
      text-decoration: none;
      font-weight: 500;
      color: var(--text-navy);
      transition: color 0.2s;
    }
    .nav-links a:hover,
    .nav-links a.active {
      color: var(--brand-blue);
    }
    .nav-buttons {
      display: flex;
      gap: 1rem;
      align-items: center;
    }
    .btn-outline-white {
      background: transparent;
      border: 1px solid var(--brand-blue);
      color: var(--brand-blue);
      padding: 0.4rem 1.2rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s;
    }
    .btn-outline-white:hover {
      background: var(--brand-blue);
      color: white;
    }
    .btn-primary {
      background: var(--grad-primary);
      color: white;
      padding: 0.4rem 1.2rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 500;
      box-shadow: 0 4px 10px rgba(0,91,255,0.2);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0,91,255,0.25);
    }
    @media (max-width: 768px) {
      .nav-links {
        display: none;
      }
    }

    /* Main content container */
    main .container {
      width: min(1200px, 92%);
      margin: 2rem auto;
    }

    /* Breadcrumb */
    .breadcrumb-nav {
      margin-bottom: 1rem;
      font-size: 0.8rem;
    }
    .breadcrumb-nav ul {
      list-style: none;
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      padding: 0;
      margin: 1rem 0;
    }
    .breadcrumb-nav li {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }
    .breadcrumb-nav li:not(:last-child)::after {
      content: "›";
      color: var(--slate);
    }
    .breadcrumb-nav a {
      text-decoration: none;
      color: var(--brand-blue);
    }

    /* Headings */
    h1 {
      font-size: 2.2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }
    h2 {
      font-size: 1.5rem;
      margin: 2rem 0 1rem;
      font-weight: 600;
    }
    section {
      margin-bottom: 2.5rem;
    }

    /* Premium tutor cards grid */
    .tutor-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1.2rem;
      margin: 1.5rem 0;
    }
    .tutor-card {
      background: var(--white);
      border-radius: 24px;
      padding: 1rem;
      text-align: center;
      box-shadow: var(--shadow-sm);
      transition: transform 0.2s, box-shadow 0.2s;
      border: 1px solid var(--border-grey);
    }
    .tutor-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
      border-color: var(--brand-blue);
    }
    .tutor-card img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
      margin-bottom: 0.5rem;
      border: 2px solid var(--pale-blue);
    }
    .tutor-card h3 {
      font-size: 1rem;
      margin: 0.3rem 0;
    }
    .tutor-card .rating {
      font-size: 0.8rem;
      color: var(--slate);
    }
    .tutor-card .btn-sm {
      margin-top: 0.5rem;
      display: inline-block;
      background: var(--brand-blue);
      color: white;
      padding: 0.3rem 0.8rem;
      border-radius: 40px;
      text-decoration: none;
      font-size: 0.75rem;
      transition: background 0.2s;
    }
    .tutor-card .btn-sm:hover {
      background: #0042CC;
    }

    /* Document list – premium card style */
    .document-list {
      margin: 1.5rem 0;
      background: var(--white);
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid var(--border-grey);
    }
    .document-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 1.2rem;
      border-bottom: 1px solid var(--border-grey);
      transition: background 0.2s;
    }
    .document-item:last-child {
      border-bottom: none;
    }
    .document-item:hover {
      background: var(--ice-blue);
    }
    .document-title-link {
      text-decoration: none;
      font-weight: 500;
      color: var(--text-navy);
    }
    .document-title-link:hover {
      color: var(--brand-blue);
    }
    .price {
      font-weight: 700;
      color: var(--brand-blue);
    }

    /* Question list */
    .question-list {
      list-style: none;
      padding: 0;
      margin: 1rem 0;
    }
    .question-list li {
      margin: 0.5rem 0;
    }
    .question-list a {
      text-decoration: none;
      color: var(--text-navy);
      display: block;
      padding: 0.6rem 0.8rem;
      border-radius: 16px;
      transition: background 0.2s, color 0.2s;
    }
    .question-list a:hover {
      background: var(--pale-blue);
      color: var(--brand-blue);
    }

    /* Related subjects – glass‑chip style */
    .related-subjects {
      margin: 2rem 0;
      text-align: center;
    }
    .related-subjects h3 {
      font-size: 1.2rem;
      margin-bottom: 0.8rem;
    }
    .related-subjects a {
      background: rgba(0,91,255,0.08);
      padding: 0.4rem 1rem;
      border-radius: 40px;
      margin: 0.2rem;
      display: inline-block;
      text-decoration: none;
      color: var(--brand-blue);
      font-size: 0.85rem;
      transition: all 0.2s;
    }
    .related-subjects a:hover {
      background: var(--brand-blue);
      color: white;
      transform: translateY(-2px);
    }

    /* Premium CTA box */
    .cta-box {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(8px);
      padding: 1.8rem;
      border-radius: 32px;
      text-align: center;
      margin: 2.5rem 0;
      border: 1px solid rgba(0,91,255,0.2);
      box-shadow: var(--shadow-sm);
    }
    .cta-box a {
      background: var(--grad-primary);
      padding: 0.4rem 1rem;
      border-radius: 40px;
      text-decoration: none;
      color: white;
      font-weight: 500;
      transition: transform 0.2s;
      display: inline-block;
    }
    .cta-box a:hover {
      transform: translateY(-2px);
    }

    /* Responsive */
    @media (max-width: 640px) {
      .tutor-grid {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 0.8rem;
      }
      h1 {
        font-size: 1.8rem;
      }
      h2 {
        font-size: 1.3rem;
      }
    }

    /* ========== FOOTER (EXACTLY AS PROVIDED – UNCHANGED) ========== */
    .premium-footer {
      background-color: #1E293B;
      color: #F1F5F9;
      padding: 4rem 5% 2rem;
      font-family: 'Jost', 'Inter', sans-serif;
      margin-top: 3rem;
      position: relative;
    }
    .premium-footer::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, #38BDF8, #38BDF8, transparent);
    }
    .footer-container {
      max-width: 1300px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      gap: 3rem;
    }
    .footer-brand {
      flex: 1.5;
      min-width: 260px;
    }
    .footer-logo-wrapper { margin-bottom: 1rem; }
    .footer-logo {
      display: inline-flex;
      align-items: baseline;
      font-size: 1.8rem;
      font-weight: 700;
      color: aliceblue;
      text-decoration: none;
      letter-spacing: -0.5px;
    }
    .footer-logo i.fa-pen-fancy {
      font-size: 1.8rem;
      margin-left: 4px;
      transform: rotate(12deg);
      color: #38BDF8;
      transition: transform 0.2s;
    }
    .footer-logo:hover i.fa-pen-fancy { transform: rotate(12deg) scale(1.05); }
    .brand-description {
      line-height: 1.5;
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
      color: #94A3B8;
    }
    .newsletter-box {
      margin: 1.5rem 0 1.8rem;
      max-width: 320px;
    }
    .newsletter-box h5 {
      color: aliceblue;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      letter-spacing: 0.5px;
    }
    .newsletter-form {
      display: flex;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 0.2rem;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .newsletter-form:focus-within {
      border-color: #38BDF8;
      box-shadow: 0 0 0 2px rgba(56,189,248,0.2);
    }
    .newsletter-form input {
      flex: 1;
      background: transparent;
      border: none;
      padding: 0.6rem 1rem;
      color: aliceblue;
      font-size: 0.85rem;
      outline: none;
    }
    .newsletter-form input::placeholder { color: rgba(255,255,255,0.4); }
    .newsletter-form button {
      background: #38BDF8;
      color: #050A18;
      border: none;
      padding: 0.4rem 1.2rem;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .newsletter-form button:hover { transform: scale(1.02); filter: brightness(1.1); }
    .newsletter-note {
      font-size: 0.7rem;
      margin-top: 0.5rem;
      opacity: 0.5;
    }
    .social-links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .social-links a {
      width: 36px;
      height: 36px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: aliceblue;
      font-size: 1rem;
      transition: all 0.25s;
      text-decoration: none;
    }
    .social-links a:hover {
      background: #38BDF8;
      transform: translateY(-3px);
      color: #050A18;
    }
    .footer-links-grid {
      flex: 4;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 2rem;
    }
    .link-column h4 {
      color: #38BDF8;
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1.2rem;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      position: relative;
      display: inline-block;
    }
    .link-column h4::after {
      content: '';
      position: absolute;
      bottom: -6px;
      left: 0;
      width: 28px;
      height: 2px;
      background: #38BDF8;
      border-radius: 2px;
    }
    .link-column ul { list-style: none; padding: 0; margin: 0; }
    .link-column ul li { margin-bottom: 0.7rem; }
    .link-column ul li a {
      text-decoration: none;
      color: #94A3B8;
      font-size: 0.85rem;
      transition: all 0.2s ease;
      display: inline-block;
    }
    .link-column ul li a:hover {
      color: #38BDF8;
      transform: translateX(4px);
    }
    .footer-bottom {
      margin-top: 3rem;
      padding-top: 1.8rem;
      border-top: 1px solid #38BDF8;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .footer-bottom p {
      font-size: 0.75rem;
      opacity: 0.7;
      margin: 0;
    }
  </style>
</head>
<body>

<header>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">StudyGlade<i class="fas fa-pen-fancy"></i></a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/document-library.html">Library</a>
        <a href="/subjects" class="active">Subjects</a>
        <a href="/pricing">Pricing</a>
      </div>
      <div class="nav-buttons">
        <a href="/login.html" class="btn-outline-white">Login</a>
        <a href="/register.html" class="btn-primary">Sign Up</a>
      </div>
    </div>
  </nav>
</header>

<main>
  <div class="container">
    <!-- Breadcrumb UI -->
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/subjects">All Subjects</a></li>
        <li><span><%= subject %></span></li>
      </ul>
    </nav>

    <h1><%= subject %> Homework Help & Online Tutors</h1>
    <p>Find expert tutors, study resources, and answers to <%= subject %> questions. Post your own question and get help within hours.</p>

    <!-- Tutors Section -->
    <section>
      <h2>Top Tutors for <%= subject %></h2>
      <% if (tutors && tutors.length) { %>
        <div class="tutor-grid">
          <% tutors.forEach(t => { %>
            <div class="tutor-card">
              <img src="<%= t.avatar || 'https://randomuser.me/api/portraits/lego/1.jpg' %>" alt="<%= t.fullName %>" loading="lazy">
              <h3><%= t.fullName %></h3>
              <div class="rating"><i class="fas fa-star"></i> <%= t.tutorProfile?.rating?.toFixed(1) || 'New' %> (<%= t.tutorProfile?.completedQuestions || 0 %> lessons)</div>
              <a href="/tutor/<%= t._id %>" class="btn-sm">View Profile</a>
            </div>
          <% }) %>
        </div>
        <p><a href="/tutor/"><strong>All Tutors</strong></a> →</p>
      <% } else { %>
        <p>No tutors listed yet for <%= subject %>. <a href="/become-tutor">Become a tutor</a> and help students.</p>
      <% } %>
    </section>

    <!-- Documents Section -->
    <section>
      <h2>Popular <%= subject %> Documents</h2>
      <% if (documents && documents.length) { %>
        <div class="document-list">
          <% documents.forEach(d => { %>
            <div class="document-item">
              <a href="/document/<%= d.slug %>" class="document-title-link"><%= d.title %></a>
              <span class="price">$<%= d.price %></span>
            </div>
          <% }) %>
        </div>
        <p><a href="/document-library.html?subject=<%= encodeURIComponent(subject) %>">Browse all <%= subject %> documents</a> →</p>
      <% } else { %>
        <p>No documents yet. Check back later or <a href="/upload-document.html">upload your own</a>.</p>
      <% } %>
    </section>

    <!-- Questions Section -->
    <section>
      <h2>Recent <%= subject %> Questions</h2>
      <% if (questions && questions.length) { %>
        <ul class="question-list">
          <% questions.forEach(q => { %>
            <li><a href="/question/<%= q._id %>"><%= q.title %></a></li>
          <% }) %>
        </ul>
        <p><a href="/questions?subject=<%= encodeURIComponent(subject) %>">See all <%= subject %> questions</a> →</p>
      <% } else { %>
        <p>No questions yet. <a href="/post-question.html">Ask a question</a> to get help from tutors.</p>
      <% } %>
    </section>

    <!-- Related Subjects (dynamic) -->
    <div class="related-subjects">
      <h3>Other Subjects You May Like</h3>
      <div>
        <% const related = ['Mathematics', 'Statistics', 'Nursing', 'Engineering', 'Computer Science']; 
           related.forEach(rel => { if (rel !== subject) { %>
          <a href="/subjects/<%= rel.toLowerCase().replace(/ /g, '-') %>"><%= rel %></a>
        <% } }); %>
        <a href="/subjects">All Subjects</a>
      </div>
    </div>

    <!-- Call to Action -->
    <div class="cta-box">
      <p>📚 Need help with <%= subject %>? <a href="/post-question.html">Post your question now</a> and get instant bids from expert tutors. 24/7 support – start improving your grades today!</p>
    </div>
  </div>
</main>

<footer class="premium-footer">
  <div class="footer-container">
    <div class="footer-brand">
      <div class="footer-logo-wrapper"><a href="/" class="footer-logo">StudyGlade<i class="fas fa-pen-fancy"></i></a></div>
      <p class="brand-description">Empowering students worldwide with expert academic help, quality resources, and a supportive learning community.</p>
      <div class="newsletter-box"><h5>Stay Updated</h5><form class="newsletter-form"><input type="email" placeholder="Enter your email" required><button type="submit">Join</button></form><p class="newsletter-note">Join 10k+ students. No spam, ever.</p></div>
      <div class="social-links"><a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
</a><a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a><a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a><a href="#" aria-label="TikTok"><i class="fab fa-tiktok"></i></a><a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a></div>
    </div>
    <div class="footer-links-grid">
      <div class="link-column"><h4>Platform</h4><ul><li><a href="index.html">Post a Question</a></li><li><a href="document-library.html">Browse Documents</a></li><li><a href="tutor-dashboard.html">Find a Tutor</a></li><li><a href="student-dashboard.html">Online Classroom</a></li><li><a href="document-library.html">Study Library</a></li><li><a href="index.html">Calendar</a></li></ul></div>
      <div class="link-column"><h4>Resources</h4><ul>
        <li><a href="document-library.html">Study Materials</a></li>
        <li><a href="document-library.html">Research Papers</a></li>
        <li><a href="document-library.html">Practice Tests</a></li>
        <li><a href="document-library.html">Subject Guides</a></li>
        <li><a href="document-library.html">Academic Tools</a></li>
        <li><a href="document-library.html">Free Resources</a></li>
        <li><a href="document-library.html"><strong>All Solved Questions</strong></a></li>
        <li><a href="document-library.html"><strong>All Subjects</strong></a></li>
        <li><a href="tutor-dashboard.html"><strong>All Tutors</strong></a></li>
