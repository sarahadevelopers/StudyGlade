<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= edit ? 'Edit' : 'New' %> Blog Post | Admin</title>
  <link rel="stylesheet" href="/admin-dashboard.css">
  <!-- Quill CSS & JS -->
   <link rel="icon" type="image/webp" href="images/studyglade-pen-favicon.webp">
<link rel="icon" type="image/png" href="images/studyglade-pen-favicon.png" sizes="32x32">
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
  <!-- Optional: Table module for Quill -->
  <script src="https://cdn.jsdelivr.net/npm/quill-table@1.1.0/dist/quill-table.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/quill-table@1.1.0/dist/quill-table.css" rel="stylesheet">
  <style>
    .form-group { margin-bottom: 1rem; }
    label { display: block; margin-bottom: 0.3rem; font-weight: 600; }
    input, textarea, select { width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px; }
    .form-actions { margin-top: 1rem; }
    #editor-container { height: 400px; background: white; border-radius: 4px; }
    /* ========== FOOTER ========== */
.premium-footer {
  background-color: #1E293B;
  color: #F1F5F9;
  padding: 4rem 5% 2rem;
  font-family: 'Jost', 'Inter', sans-serif;
  margin-top: 3rem;
  position: relative;
}
.premium-footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, #38BDF8, #38BDF8, transparent);
}
.footer-container {
  max-width: 1300px;
  margin: 0 auto;
  display: flex;
  flex-wrap: wrap;
  gap: 3rem;
}
.footer-brand {
  flex: 1.5;
  min-width: 260px;
}
.footer-logo-wrapper { margin-bottom: 1rem; }
.footer-logo {
  display: inline-flex;
  align-items: baseline;
  font-size: 1.8rem;
  font-weight: 700;
  color: aliceblue;
  text-decoration: none;
  letter-spacing: -0.5px;
}
.footer-logo i.fa-pen-fancy {
  font-size: 1.8rem;
  margin-left: 4px;
  transform: rotate(12deg);
  color: #38BDF8;
  transition: transform 0.2s;
}
.footer-logo:hover i.fa-pen-fancy { transform: rotate(12deg) scale(1.05); }
.brand-description {
  line-height: 1.5;
  font-size: 0.9rem;
  margin-bottom: 1.5rem;
  color: #94A3B8;
}
.newsletter-box {
  margin: 1.5rem 0 1.8rem;
  max-width: 320px;
}
.newsletter-box h5 {
  color: aliceblue;
  font-size: 0.85rem;
  font-weight: 600;
  margin-bottom: 0.75rem;
  letter-spacing: 0.5px;
}
.newsletter-form {
  display: flex;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  padding: 0.2rem;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.newsletter-form:focus-within {
  border-color: #38BDF8;
  box-shadow: 0 0 0 2px rgba(56,189,248,0.2);
}
.newsletter-form input {
  flex: 1;
  background: transparent;
  border: none;
  padding: 0.6rem 1rem;
  color: aliceblue;
  font-size: 0.85rem;
  outline: none;
}
.newsletter-form input::placeholder { color: rgba(255,255,255,0.4); }
.newsletter-form button {
  background: #38BDF8;
  color: #050A18;
  border: none;
  padding: 0.4rem 1.2rem;
  border-radius: 10px;
  font-weight: 700;
  font-size: 0.8rem;
  cursor: pointer;
  transition: all 0.2s ease;
}
.newsletter-form button:hover { transform: scale(1.02); filter: brightness(1.1); }
.newsletter-note {
  font-size: 0.7rem;
  margin-top: 0.5rem;
  opacity: 0.5;
}
.social-links {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}
.social-links a {
  width: 36px;
  height: 36px;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: aliceblue;
  font-size: 1rem;
  transition: all 0.25s;
  text-decoration: none;
}
.social-links a:hover {
  background: #38BDF8;
  transform: translateY(-3px);
  color: #050A18;
}
.footer-links-grid {
  flex: 4;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 2rem;
}
.link-column h4 {
  color: #38BDF8;
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 1.2rem;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  position: relative;
  display: inline-block;
}
.link-column h4::after {
  content: '';
  position: absolute;
  bottom: -6px;
  left: 0;
  width: 28px;
  height: 2px;
  background: #38BDF8;
  border-radius: 2px;
}
.link-column ul { list-style: none; padding: 0; margin: 0; }
.link-column ul li { margin-bottom: 0.7rem; }
.link-column ul li a {
  text-decoration: none;
  color: #94A3B8;
  font-size: 0.85rem;
  transition: all 0.2s ease;
  display: inline-block;
}
.link-column ul li a:hover {
  color: #38BDF8;
  transform: translateX(4px);
}
.footer-bottom {
  margin-top: 3rem;
  padding-top: 1.8rem;
  border-top: 1px solid #38BDF8;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer-bottom p {
  font-size: 0.75rem;
  opacity: 0.7;
  margin: 0;
}
  </style>
</head>
<body>
  <div class="admin-container">
    <h1><%= edit ? 'Edit Post' : 'New Post' %></h1>
    <form method="POST" action="/admin/blog<%= edit ? '/' + post._id + '?_method=PUT' : '' %>" id="blogForm">
      <div class="form-group">
        <label>Title *</label>
        <input type="text" name="title" value="<%= post ? post.title : '' %>" required>
      </div>
      <div class="form-group">
        <label>Slug (auto‑generated if empty)</label>
        <input type="text" name="slug" value="<%= post ? post.slug : '' %>" placeholder="leave empty to auto-generate">
      </div>
      <!-- Quill editor container -->
      <div class="form-group">
        <label>Content *</label>
        <div id="editor-container"></div>
        <input type="hidden" name="content" id="content">
      </div>
      <div class="form-group">
        <label>Excerpt (short description, optional)</label>
        <textarea name="excerpt" rows="3"><%= post ? post.excerpt : '' %></textarea>
      </div>
      <div class="form-group">
        <label>Author</label>
        <input type="text" name="author" value="<%= post ? post.author : 'StudyGlade Team' %>">
      </div>
      <div class="form-group">
        <label>Featured Image URL</label>
        <input type="text" name="featuredImage" value="<%= post ? post.featuredImage : '' %>">
      </div>
      <div class="form-group">
        <label>Published</label>
        <input type="checkbox" name="isPublished" <%= post && post.isPublished ? 'checked' : '' %>>
      </div>
      <div class="form-group">
        <label>Publish Date (optional)</label>
        <input type="datetime-local" name="publishedAt" value="<%= post && post.publishedAt ? new Date(post.publishedAt).toISOString().slice(0,16) : '' %>">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-primary">Save</button>
        <a href="/admin/blog" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>
  <script>
  // Register table module if available
  if (typeof Quill !== 'undefined' && typeof quillTable !== 'undefined') {
    Quill.register({ 'modules/table': quillTable.Table }, true);
  }

  const toolbarOptions = [
    ['bold', 'italic', 'underline', 'strike'],
    ['blockquote', 'code-block'],
    [{ 'header': 1 }, { 'header': 2 }],
    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
    [{ 'indent': '-1'}, { 'indent': '+1' }],
    [{ 'align': [] }],
    ['link', 'image'],
    ['clean'],
    ['table']
  ];

  const quill = new Quill('#editor-container', {
    theme: 'snow',
    modules: {
      toolbar: toolbarOptions,
      table: true
    }
  });

  // Load existing content from hidden textarea (safe, no parsing issues)
  const existingContent = document.getElementById('existingContent');
  if (existingContent && existingContent.value) {
    quill.root.innerHTML = existingContent.value;
  }

  // Custom image upload handler
  const toolbar = quill.getModule('toolbar');
  toolbar.addHandler('image', () => {
    const input = document.createElement('input');
    input.setAttribute('type', 'file');
    input.setAttribute('accept', 'image/*');
    input.click();
    input.onchange = async () => {
      const file = input.files[0];
      const formData = new FormData();
      formData.append('image', file);
      try {
        const res = await fetch('/admin/blog/upload-image', { method: 'POST', body: formData });
        const data = await res.json();
        const range = quill.getSelection(true);
        quill.insertEmbed(range.index, 'image', data.url);
      } catch (err) {
        console.error('Image upload failed:', err);
        alert('Image upload failed. Please try again.');
      }
    };
  });

  // Sync hidden input before form submission
  const form = document.getElementById('blogForm');
  const hiddenContent = document.getElementById('content');
  form.addEventListener('submit', () => {
    hiddenContent.value = quill.root.innerHTML;
  });
</script>
</body>
</html>