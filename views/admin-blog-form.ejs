<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= edit ? 'Edit' : 'New' %> Blog Post | Admin</title>
  <link rel="icon" type="image/webp" href="images/studyglade-pen-favicon.webp">
  <link rel="icon" type="image/png" href="images/studyglade-pen-favicon.png" sizes="32x32">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/admin-dashboard.css">
  
  <!-- Quill CSS & JS (no table module) -->
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

  <style>
    /* ---------- Premium Design System (matching admin dashboard) ---------- */
    :root {
      --navy: #061B49;
      --deep-blue: #0B2E75;
      --brand-blue: #005BFF;
      --royal-blue: #2563EB;
      --sky-blue: #38BDF8;
      --ice-blue: #EFF6FF;
      --pale-blue: #DBEAFE;
      --white: #FFFFFF;
      --text-navy: #0F172A;
      --slate: #64748B;
      --border-grey: #E2E8F0;
      --shadow-sm: 0 4px 10px -2px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.02);
      --shadow-md: 0 10px 20px -5px rgba(0,0,0,0.08);
      --grad-primary: linear-gradient(135deg, #005BFF 0%, #2563EB 60%, #38BDF8 100%);
    }

    /* Glass‑morphism navbar */
    .navbar {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(226, 232, 240, 0.6);
      padding: 0.75rem 0;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    .navbar .container {
      width: min(1200px, 92%);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--text-navy);
      text-decoration: none;
    }
    .logo i {
      color: var(--brand-blue);
      font-size: 1.6rem;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }
    .nav-links a {
      text-decoration: none;
      font-weight: 500;
      color: var(--text-navy);
      transition: color 0.2s;
    }
    .nav-links a:hover {
      color: var(--brand-blue);
    }
    .btn-outline-white {
      background: transparent;
      border: 1px solid var(--brand-blue);
      color: var(--brand-blue);
      padding: 0.4rem 1.2rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s;
    }
    .btn-outline-white:hover {
      background: var(--brand-blue);
      color: white;
    }

    /* Main container */
    .admin-container {
      max-width: 1000px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    h1 {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .form-card {
      background: var(--white);
      border-radius: 32px;
      box-shadow: var(--shadow-md);
      padding: 2rem;
      margin-top: 1rem;
    }
    .form-group {
      margin-bottom: 1.2rem;
    }
    label {
      display: block;
      margin-bottom: 0.4rem;
      font-weight: 600;
      color: var(--text-navy);
    }
    input, textarea, select {
      width: 100%;
      padding: 0.6rem 0.8rem;
      border: 1px solid var(--border-grey);
      border-radius: 16px;
      font-family: inherit;
      font-size: 0.9rem;
      transition: all 0.2s;
    }
    input:focus, textarea:focus, select:focus {
      outline: none;
      border-color: var(--brand-blue);
      box-shadow: 0 0 0 2px rgba(0,91,255,0.1);
    }
    #editor-container {
      height: 400px;
      background: white;
      border-radius: 16px;
      border: 1px solid var(--border-grey);
    }
    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .checkbox-group input {
      width: auto;
    }
    .form-actions {
      display: flex;
      gap: 1rem;
      margin-top: 2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border-grey);
    }
    .btn-primary {
      background: var(--grad-primary);
      color: white;
      border: none;
      padding: 0.6rem 1.2rem;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 2px 6px rgba(0,91,255,0.2);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(0,91,255,0.25);
    }
    .btn-outline {
      background: transparent;
      border: 1px solid var(--brand-blue);
      color: var(--brand-blue);
      padding: 0.6rem 1.2rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 500;
      display: inline-block;
      transition: all 0.2s;
    }
    .btn-outline:hover {
      background: var(--brand-blue);
      color: white;
      transform: translateY(-2px);
    }
    .required {
      color: #EF4444;
    }
    small {
      color: var(--slate);
      font-size: 0.7rem;
    }
  </style>
</head>
<body>

<!-- Premium Glass‑morphism Navbar -->
<nav class="navbar">
  <div class="container">
    <a href="/admin-dashboard.html" class="logo">StudyGlade<i class="fas fa-pen-fancy"></i></a>
    <div class="nav-links">
      <a href="/admin-dashboard.html">Dashboard</a>
      <a href="/admin/blog">Blog</a>
    </div>
    <div>
      <a href="/admin/blog" class="btn-outline-white"><i class="fas fa-arrow-left"></i> Back to List</a>
    </div>
  </div>
</nav>

<main class="admin-container">
  <h1><%= edit ? '✏️ Edit Post' : '📝 Create New Post' %></h1>
  <p class="subhead" style="color: var(--slate); margin-bottom: 1rem;">
    <%= edit ? 'Update your blog post content and settings.' : 'Write a new blog post using the rich editor below.' %>
  </p>

  <div class="form-card">
    <form method="POST" action="/admin/blog<%= edit ? '/' + post._id + '?_method=PUT' : '' %>" id="blogForm">
      <div class="form-group">
        <label>Title <span class="required">*</span></label>
        <input type="text" name="title" value="<%= post ? post.title : '' %>" required placeholder="e.g., How to Ace Your Exams">
      </div>
      <div class="form-group">
        <label>Slug (auto‑generated if empty)</label>
        <input type="text" name="slug" value="<%= post ? post.slug : '' %>" placeholder="leave empty to auto-generate">
        <small>URL‑friendly version of the title (e.g., how-to-ace-exams).</small>
      </div>
      <!-- Quill editor container -->
      <div class="form-group">
        <label>Content <span class="required">*</span></label>
        <div id="editor-container"></div>
        <input type="hidden" name="content" id="content">
      </div>
      <!-- Hidden textarea to safely store existing content -->
      <textarea id="existingContent" style="display:none;"><%= post && post.content ? post.content : '' %></textarea>
      <div class="form-group">
        <label>Excerpt (short description, optional)</label>
        <textarea name="excerpt" rows="3" placeholder="A short preview of the post (will be auto‑generated if empty)."><%= post ? post.excerpt : '' %></textarea>
        <small>Used in blog listings and SEO meta description.</small>
      </div>
      <div class="form-group">
        <label>Author</label>
        <input type="text" name="author" value="<%= post ? post.author : 'StudyGlade Team' %>">
      </div>
      <div class="form-group">
        <label>Featured Image URL</label>
        <input type="text" name="featuredImage" value="<%= post ? post.featuredImage : '' %>" placeholder="https://example.com/image.jpg">
        <small>Displayed at the top of the blog post and in social shares.</small>
      </div>
      <div class="form-group checkbox-group">
        <input type="checkbox" name="isPublished" <%= post && post.isPublished ? 'checked' : '' %>>
        <label style="margin-bottom: 0;">Published</label>
      </div>
      <div class="form-group">
        <label>Publish Date (optional)</label>
        <input type="datetime-local" name="publishedAt" value="<%= post && post.publishedAt ? new Date(post.publishedAt).toISOString().slice(0,16) : '' %>">
        <small>If empty and “Published” is checked, the current date/time will be used.</small>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Save Post</button>
        <a href="/admin/blog" class="btn-outline"><i class="fas fa-times"></i> Cancel</a>
      </div>
    </form>
  </div>
</main>

<script>
  const toolbarOptions = [
    ['bold', 'italic', 'underline', 'strike'],
    ['blockquote', 'code-block'],
    [{ 'header': 1 }, { 'header': 2 }],
    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
    [{ 'indent': '-1'}, { 'indent': '+1' }],
    [{ 'align': [] }],
    ['link', 'image'],
    ['clean']
  ];

  const quill = new Quill('#editor-container', {
    theme: 'snow',
    modules: {
      toolbar: toolbarOptions
    }
  });

  // Load existing content from hidden textarea
  const existingContent = document.getElementById('existingContent');
  if (existingContent && existingContent.value) {
    quill.root.innerHTML = existingContent.value;
  }

  // Custom image upload handler
  const toolbar = quill.getModule('toolbar');
  toolbar.addHandler('image', () => {
    const input = document.createElement('input');
    input.setAttribute('type', 'file');
    input.setAttribute('accept', 'image/*');
    input.click();
    input.onchange = async () => {
      const file = input.files[0];
      const formData = new FormData();
      formData.append('image', file);
      try {
        const res = await fetch('/admin/blog/upload-image', { method: 'POST', body: formData });
        const data = await res.json();
        const range = quill.getSelection(true);
        quill.insertEmbed(range.index, 'image', data.url);
      } catch (err) {
        console.error('Image upload failed:', err);
        alert('Image upload failed. Please try again.');
      }
    };
  });

  // Sync hidden input before form submission
  const form = document.getElementById('blogForm');
  const hiddenContent = document.getElementById('content');
  form.addEventListener('submit', () => {
    hiddenContent.value = quill.root.innerHTML;
  });
</script>
</body>
</html>