<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog Management | StudyGlade Admin</title>
  <link rel="icon" type="image/webp" href="images/studyglade-official-favicon.jpg">
  <link rel="icon" type="image/png" href="images/studyglade-pen-favicon.png" sizes="32x32">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/admin-dashboard.css">
  
  <style>
    /* ---------- Premium Design System (matching admin dashboard) ---------- */
    :root {
      --navy: #061B49;
      --deep-blue: #0B2E75;
      --brand-blue: #005BFF;
      --royal-blue: #2563EB;
      --sky-blue: #38BDF8;
      --ice-blue: #EFF6FF;
      --pale-blue: #DBEAFE;
      --white: #FFFFFF;
      --text-navy: #0F172A;
      --slate: #64748B;
      --border-grey: #E2E8F0;
      --shadow-sm: 0 4px 10px -2px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.02);
      --shadow-md: 0 10px 20px -5px rgba(0,0,0,0.08);
      --grad-primary: linear-gradient(135deg, #005BFF 0%, #2563EB 60%, #38BDF8 100%);
    }

    /* Glass‑morphism navbar (matching admin dashboard) */
    .navbar {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(226, 232, 240, 0.6);
      padding: 0.75rem 0;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    .navbar .container {
      width: min(1200px, 92%);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--text-navy);
      text-decoration: none;
    }
    .logo i {
      color: var(--brand-blue);
      font-size: 1.6rem;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }
    .nav-links a {
      text-decoration: none;
      font-weight: 500;
      color: var(--text-navy);
      transition: color 0.2s;
    }
    .nav-links a:hover {
      color: var(--brand-blue);
    }
    .btn-outline-white {
      background: transparent;
      border: 1px solid var(--brand-blue);
      color: var(--brand-blue);
      padding: 0.4rem 1.2rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s;
    }
    .btn-outline-white:hover {
      background: var(--brand-blue);
      color: white;
    }
    .btn-primary {
      background: var(--grad-primary);
      color: white;
      padding: 0.4rem 1.2rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 500;
      box-shadow: 0 4px 10px rgba(0,91,255,0.2);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0,91,255,0.25);
    }

    /* Main container */
    .admin-container {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    h1 {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .subhead {
      color: var(--slate);
      margin-bottom: 1.5rem;
    }

    /* Action bar */
    .action-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .btn-primary-lg {
      background: var(--grad-primary);
      color: white;
      padding: 0.6rem 1.2rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 2px 6px rgba(0,91,255,0.2);
    }
    .btn-primary-lg:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(0,91,255,0.25);
    }

    /* Blog posts grid */
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
      margin-top: 1rem;
    }
    .blog-card {
      background: var(--white);
      border-radius: 24px;
      padding: 1.2rem;
      box-shadow: var(--shadow-sm);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      border: 1px solid var(--border-grey);
    }
    .blog-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
      border-color: var(--brand-blue);
    }
    .blog-title {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text-navy);
    }
    .blog-meta {
      font-size: 0.75rem;
      color: var(--slate);
      margin-bottom: 0.75rem;
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .status-badge {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 40px;
      font-size: 0.7rem;
      font-weight: 600;
    }
    .status-published {
      background: #D1FAE5;
      color: #065F46;
    }
    .status-draft {
      background: #FEF3C7;
      color: #B45309;
    }
    .slug {
      font-family: monospace;
      font-size: 0.7rem;
      background: var(--ice-blue);
      padding: 0.2rem 0.4rem;
      border-radius: 12px;
    }
    .card-actions {
      display: flex;
      gap: 0.5rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }
    .btn-sm {
      padding: 0.3rem 0.8rem;
      font-size: 0.75rem;
      border-radius: 40px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-outline {
      background: transparent;
      border: 1px solid var(--brand-blue);
      color: var(--brand-blue);
    }
    .btn-outline:hover {
      background: var(--brand-blue);
      color: white;
      transform: translateY(-1px);
    }
    .btn-danger {
      background: #EF4444;
      color: white;
      border: none;
    }
    .btn-danger:hover {
      background: #DC2626;
      transform: translateY(-1px);
    }
    .btn-sm form {
      display: inline;
    }
  </style>
</head>
<body>

<!-- Premium Navbar (matching admin dashboard) -->
<nav class="navbar">
  <div class="container">
    <a href="/admin-dashboard.html" class="logo">StudyGlade<i class="fas fa-pen-fancy"></i></a>
    <div class="nav-links">
      <a href="/admin-dashboard.html">Dashboard</a>
      <a href="/admin/blog" class="active">Blog</a>
    </div>
    <div>
      <a href="/admin-dashboard.html" class="btn-outline-white">← Back to Dashboard</a>
    </div>
  </div>
</nav>

<main class="admin-container">
  <h1>Blog Posts</h1>
  <p class="subhead">Manage your blog posts – create, edit, or delete content.</p>

  <div class="action-bar">
    <a href="/admin/blog/new" class="btn-primary-lg"><i class="fas fa-plus-circle"></i> Create New Post</a>
  </div>

  <% if (posts && posts.length) { %>
    <div class="blog-grid">
      <% posts.forEach(post => { %>
        <div class="blog-card">
          <div class="blog-title"><%= post.title %></div>
          <div class="blog-meta">
            <span class="status-badge <%= post.isPublished ? 'status-published' : 'status-draft' %>">
              <%= post.isPublished ? 'Published' : 'Draft' %>
            </span>
            <span class="slug">Slug: <%= post.slug %></span>
          </div>
          <div class="card-actions">
            <a href="/admin/blog/<%= post._id %>/edit" class="btn-sm btn-outline"><i class="fas fa-edit"></i> Edit</a>
            <form action="/admin/blog/<%= post._id %>?_method=DELETE" method="POST" style="display:inline;">
              <button type="submit" class="btn-sm btn-danger" onclick="return confirm('Delete this post permanently?')"><i class="fas fa-trash-alt"></i> Delete</button>
            </form>
            <a href="/blog/<%= post.slug %>" target="_blank" class="btn-sm btn-outline"><i class="fas fa-external-link-alt"></i> View</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="card" style="text-align: center; padding: 3rem;">
      <p>No blog posts yet. <a href="/admin/blog/new">Create your first post</a>.</p>
    </div>
  <% } %>
</main>

<script>
  // Simple confirmation for delete (already handled inline)
</script>
</body>
</html>