<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>All Completed Questions | StudyGlade</title>
  <% 
    let pageDesc = `Browse ${totalPages > 1 ? `page ${currentPage} of ` : ''}${totalQuestions || 'thousands of'} solved homework questions and answers from StudyGlade tutors. Filter by subject or find the help you need.`;
  %>
  <meta name="description" content="<%= pageDesc %>">
  <meta name="keywords" content="solved questions, homework answers, study help, tutoring">
  <link rel="canonical" href="https://studyglade.com/questions<%= currentPage > 1 ? '?page=' + currentPage : '' %>">
  <meta property="og:title" content="All Completed Questions | StudyGlade">
  <meta property="og:description" content="<%= pageDesc %>">
  <meta property="og:image" content="https://studyglade.com/og-logo.png">
  <meta property="og:url" content="https://studyglade.com/questions">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="icon" type="image/webp" href="images/studyglade-pen-favicon.webp">
  <link rel="icon" type="image/png" href="images/studyglade-pen-favicon.png" sizes="32x32">
  <link rel="stylesheet" href="/index.css">
  
  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studyglade.com/" },
      { "@type": "ListItem", "position": 2, "name": "All Solved Questions", "item": "https://studyglade.com/questions" }
    ]
  }
  </script>
  
  <!-- WebPage Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "All Completed Questions",
    "description": "<%= pageDesc %>",
    "url": "https://studyglade.com/questions",
    "isPartOf": { "@type": "WebSite", "name": "StudyGlade", "url": "https://studyglade.com/" }
  }
  </script>
  
  <style>
    /* ---------- Premium Design System (matching homepage) ---------- */
    :root {
      --navy: #061B49;
      --deep-blue: #0B2E75;
      --brand-blue: #005BFF;
      --royal-blue: #2563EB;
      --sky-blue: #38BDF8;
      --ice-blue: #EFF6FF;
      --pale-blue: #DBEAFE;
      --white: #FFFFFF;
      --text-navy: #0F172A;
      --slate: #64748B;
      --border-grey: #E2E8F0;
      --shadow-sm: 0 4px 10px -2px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.02);
      --shadow-md: 0 10px 20px -5px rgba(0,0,0,0.08);
      --grad-primary: linear-gradient(135deg, #005BFF 0%, #2563EB 60%, #38BDF8 100%);
    }

    /* Glass‑morphism navbar */
    .navbar {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(226, 232, 240, 0.6);
      padding: 0.75rem 0;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    .navbar .container {
      width: min(1200px, 92%);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--text-navy);
      text-decoration: none;
    }
    .logo i {
      color: var(--brand-blue);
      font-size: 1.6rem;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }
    .nav-links a {
      text-decoration: none;
      font-weight: 500;
      color: var(--text-navy);
      transition: color 0.2s;
    }
    .nav-links a:hover,
    .nav-links a.active {
      color: var(--brand-blue);
    }
    .nav-buttons {
      display: flex;
      gap: 1rem;
      align-items: center;
    }
    .btn-outline-white {
      background: transparent;
      border: 1px solid var(--brand-blue);
      color: var(--brand-blue);
      padding: 0.4rem 1.2rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s;
    }
    .btn-outline-white:hover {
      background: var(--brand-blue);
      color: white;
    }
    .btn-primary {
      background: var(--grad-primary);
      color: white;
      padding: 0.4rem 1.2rem;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 500;
      box-shadow: 0 4px 10px rgba(0,91,255,0.2);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0,91,255,0.25);
    }
    @media (max-width: 768px) {
      .nav-links {
        display: none;
      }
    }

    /* Main content */
    main .container {
      width: min(1200px, 92%);
      margin: 2rem auto;
    }

    /* Breadcrumb */
    .breadcrumb-nav {
      margin-bottom: 1rem;
      font-size: 0.8rem;
    }
    .breadcrumb-nav ul {
      list-style: none;
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      padding: 0;
      margin: 1rem 0;
    }
    .breadcrumb-nav li {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }
    .breadcrumb-nav li:not(:last-child)::after {
      content: "›";
      color: var(--slate);
    }
    .breadcrumb-nav a {
      text-decoration: none;
      color: var(--brand-blue);
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }
    .lead {
      font-size: 1.1rem;
      color: var(--slate);
      margin-bottom: 1.5rem;
    }

    /* Premium question grid */
    .questions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
      margin: 2rem 0;
    }
    .question-card {
      background: var(--white);
      border-radius: 28px;
      padding: 1.2rem;
      box-shadow: var(--shadow-sm);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      border: 1px solid var(--border-grey);
      display: flex;
      flex-direction: column;
    }
    .question-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
      border-color: var(--brand-blue);
    }
    .question-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }
    .question-title a {
      text-decoration: none;
      color: var(--text-navy);
      transition: color 0.2s;
    }
    .question-title a:hover {
      color: var(--brand-blue);
    }
    .question-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 0.5rem 0 0;
      font-size: 0.7rem;
      color: var(--slate);
    }
    .question-category a {
      background: var(--pale-blue);
      padding: 0.2rem 0.6rem;
      border-radius: 40px;
      text-decoration: none;
      color: var(--brand-blue);
      font-weight: 500;
      font-size: 0.7rem;
      transition: background 0.2s;
    }
    .question-category a:hover {
      background: var(--brand-blue);
      color: white;
    }
    .question-date {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }

    /* Pagination */
    .pagination {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin: 2rem 0;
      flex-wrap: wrap;
    }
    .pagination a, .pagination span {
      padding: 0.4rem 0.8rem;
      border-radius: 40px;
      background: var(--pale-blue);
      color: var(--brand-blue);
      text-decoration: none;
      transition: all 0.2s;
    }
    .pagination a:hover {
      background: var(--brand-blue);
      color: white;
    }
    .pagination a.active {
      background: var(--brand-blue);
      color: white;
      pointer-events: none;
    }
    .disabled {
      opacity: 0.5;
      pointer-events: none;
    }

    /* ========== FOOTER (EXACTLY AS PROVIDED – UNCHANGED) ========== */
    .premium-footer {
      background-color: #1E293B;
      color: #F1F5F9;
      padding: 4rem 5% 2rem;
      font-family: 'Jost', 'Inter', sans-serif;
      margin-top: 3rem;
      position: relative;
    }
    .premium-footer::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, #38BDF8, #38BDF8, transparent);
    }
    .footer-container {
      max-width: 1300px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      gap: 3rem;
    }
    .footer-brand {
      flex: 1.5;
      min-width: 260px;
    }
    .footer-logo-wrapper { margin-bottom: 1rem; }
    .footer-logo {
      display: inline-flex;
      align-items: baseline;
      font-size: 1.8rem;
      font-weight: 700;
      color: aliceblue;
      text-decoration: none;
      letter-spacing: -0.5px;
    }
    .footer-logo i.fa-pen-fancy {
      font-size: 1.8rem;
      margin-left: 4px;
      transform: rotate(12deg);
      color: #38BDF8;
      transition: transform 0.2s;
    }
    .footer-logo:hover i.fa-pen-fancy { transform: rotate(12deg) scale(1.05); }
    .brand-description {
      line-height: 1.5;
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
      color: #94A3B8;
    }
    .newsletter-box {
      margin: 1.5rem 0 1.8rem;
      max-width: 320px;
    }
    .newsletter-box h5 {
      color: aliceblue;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      letter-spacing: 0.5px;
    }
    .newsletter-form {
      display: flex;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 0.2rem;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .newsletter-form:focus-within {
      border-color: #38BDF8;
      box-shadow: 0 0 0 2px rgba(56,189,248,0.2);
    }
    .newsletter-form input {
      flex: 1;
      background: transparent;
      border: none;
      padding: 0.6rem 1rem;
      color: aliceblue;
      font-size: 0.85rem;
      outline: none;
    }
    .newsletter-form input::placeholder { color: rgba(255,255,255,0.4); }
    .newsletter-form button {
      background: #38BDF8;
      color: #050A18;
      border: none;
      padding: 0.4rem 1.2rem;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .newsletter-form button:hover { transform: scale(1.02); filter: brightness(1.1); }
    .newsletter-note {
      font-size: 0.7rem;
      margin-top: 0.5rem;
      opacity: 0.5;
    }
    .social-links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .social-links a {
      width: 36px;
      height: 36px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: aliceblue;
      font-size: 1rem;
      transition: all 0.25s;
      text-decoration: none;
    }
    .social-links a:hover {
      background: #38BDF8;
      transform: translateY(-3px);
      color: #050A18;
    }
    .footer-links-grid {
      flex: 4;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 2rem;
    }
    .link-column h4 {
      color: #38BDF8;
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1.2rem;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      position: relative;
      display: inline-block;
    }
    .link-column h4::after {
      content: '';
      position: absolute;
      bottom: -6px;
      left: 0;
      width: 28px;
      height: 2px;
      background: #38BDF8;
      border-radius: 2px;
    }
    .link-column ul { list-style: none; padding: 0; margin: 0; }
    .link-column ul li { margin-bottom: 0.7rem; }
    .link-column ul li a {
      text-decoration: none;
      color: #94A3B8;
      font-size: 0.85rem;
      transition: all 0.2s ease;
      display: inline-block;
    }
    .link-column ul li a:hover {
      color: #38BDF8;
      transform: translateX(4px);
    }
    .footer-bottom {
      margin-top: 3rem;
      padding-top: 1.8rem;
      border-top: 1px solid #38BDF8;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .footer-bottom p {
      font-size: 0.75rem;
      opacity: 0.7;
      margin: 0;
    }
  </style>
</head>
<body>

<header>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">StudyGlade<i class="fas fa-pen-fancy"></i></a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/document-library.html">Library</a>
        <a href="/subjects">Subjects</a>
        <a href="/questions" class="active">Solved Questions</a>
        <a href="/pricing">Pricing</a>
      </div>
      <div class="nav-buttons">
        <a href="/login.html" class="btn-outline-white">Login</a>
        <a href="/register.html" class="btn-primary">Sign Up</a>
      </div>
    </div>
  </nav>
</header>

<main>
  <div class="container">
    <!-- Breadcrumb UI -->
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <ul>
        <li><a href="/">Home</a></li>
        <li><span>All Solved Questions</span></li>
      </ul>
    </nav>

    <h1>All Completed Questions</h1>
    <p class="lead">Browse through <strong><%= totalQuestions || 'thousands of' %></strong> solved questions answered by expert tutors. Find answers by subject or use our search.</p>

    <div class="questions-archive">
      <% if (questions && questions.length) { %>
        <div class="questions-grid">
          <% questions.forEach(q => { 
            const subjectName = q.category || 'General';
            const slug = subjectName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
          %>
            <div class="question-card">
              <div class="question-title">
                <a href="/question/<%= q._id %>"><%= q.title %></a>
              </div>
              <div class="question-meta">
                <span class="question-category"><a href="/subjects/<%= slug %>"><%= subjectName %></a></span>
                <span class="question-date"><i class="far fa-calendar-alt"></i> <%= new Date(q.updatedAt).toLocaleDateString() %></span>
              </div>
            </div>
          <% }) %>
        </div>

        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% if (hasPrev) { %>
              <a href="/questions?page=<%= prevPage %>" class="prev-page"><i class="fas fa-chevron-left"></i> Previous</a>
            <% } else { %>
              <span class="disabled"><i class="fas fa-chevron-left"></i> Previous</span>
            <% } %>
            
            <% 
              let startPage = Math.max(1, currentPage - 2);
              let endPage = Math.min(totalPages, currentPage + 2);
              if (endPage - startPage < 4) {
                if (startPage === 1) endPage = Math.min(totalPages, 5);
                if (endPage === totalPages) startPage = Math.max(1, totalPages - 4);
              }
              for (let i = startPage; i <= endPage; i++) { 
            %>
              <a href="/questions?page=<%= i %>" <%= i === currentPage ? 'class="active"' : '' %>><%= i %></a>
            <% } %>
            
            <% if (hasNext) { %>
              <a href="/questions?page=<%= nextPage %>" class="next-page">Next <i class="fas fa-chevron-right"></i></a>
            <% } else { %>
              <span class="disabled">Next <i class="fas fa-chevron-right"></i></span>
            <% } %>
          </div>
        <% } %>
      <% } else { %>
        <p>No completed questions yet. Check back later or <a href="/post-question.html">post your own question</a>.</p>
      <% } %>
    </div>
  </div>
</main>

<footer class="premium-footer">
  <div class="footer-container">
    <div class="footer-brand">
      <div class="footer-logo-wrapper"><a href="/" class="footer-logo">StudyGlade<i class="fas fa-pen-fancy"></i></a></div>
      <p class="brand-description">Empowering students worldwide with expert academic help, quality resources, and a supportive learning community.</p>
      <div class="newsletter-box"><h5>Stay Updated</h5><form class="newsletter-form"><input type="email" placeholder="Enter your email" required><button type="submit">Join</button></form><p class="newsletter-note">Join 10k+ students. No spam, ever.</p></div>
      <div class="social-links"><a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
</a><a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a><a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a><a href="#" aria-label="TikTok"><i class="fab fa-tiktok"></i></a><a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a></div>
    </div>
    <div class="footer-links-grid">
      <div class="link-column"><h4>Platform</h4><ul><li><a href="index.html">Post a Question</a></li><li><a href="document-library.html">Browse Documents</a></li><li><a href="tutor-dashboard.html">Find a Tutor</a></li><li><a href="student-dashboard.html">Online Classroom</a></li><li><a href="document-library.html">Study Library</a></li><li><a href="index.html">Calendar</a></li></ul></div>
      <div class="link-column"><h4>Resources</h4><ul>
        <li><a href="document-library.html">Study Materials</a></li>
        <li><a href="document-library.html">Research Papers</a></li>
        <li><a href="document-library.html">Practice Tests</a></li>
        <li><a href="document-library.html">Subject Guides</a></li>
        <li><a href="document-library.html">Academic Tools</a></li>
        <li><a href="document-library.html">Free Resources</a></li>
        <li><a href="document-library.html"><strong>All Solved Questions</strong></a></li>
        <li><a href="document-library.html"><strong>All Subjects</strong></a></li>
        <li><a href="tutor-dashboard.html"><strong>All Tutors</strong></a></li>
      </ul></div>
      <div class="link-column"><h4>Support</h4><ul><li><a href="terms.html">Help Centre</a></li><li><a href="contact.html">Contact Us</a></li><li><a href="terms.html">Live Chat</a></li><li><a href="terms.html">How It Works</a></li><li><a href="terms.html">Tutor Support</a></li><li><a href="terms.html">Feedback</a></li></ul></div>
      <div class="link-column"><h4>Legal</h4><ul><li><a href="privacy.html">Privacy Policy</a></li><li><a href="terms.html">Terms of Service</a></li><li><a href="terms.html">Refund Policy</a></li><li><a href="terms.html">Cookie Policy</a></li><li><a href="terms.html">Honor Code</a></li></ul></div>
      <div class="link-column"><h4>About Us</h4><ul><li><a href="about.html">About StudyGlade</a></li><li><a href="terms.html">Careers</a></li><li><a href="terms.html">Press & Media</a></li><li><a href="/blog">Blog</a></li><li><a href="terms.html">Partnerships</a></li></ul></div>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2015 – <span id="currentYear"></span> StudyGlade. All rights reserved.</p>
    <button class="back-to-top" id="backToTopBtn" style="background-color: #38BDF8; color: aliceblue;">
      <i class="fas fa-arrow-up"></i> Top
    </button>
  </div>
</footer>

<script>
  const yearSpan = document.getElementById('currentYear');
  if (yearSpan) yearSpan.textContent = new Date().getFullYear();
  const backToTopBtn = document.getElementById('backToTopBtn');
  if (backToTopBtn) backToTopBtn.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
</body>
</html>