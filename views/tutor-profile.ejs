<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= tutor.fullName %> – Expert Tutor | StudyGlade</title>
  <meta name="description" content="<%= tutor.fullName %> is a verified tutor on StudyGlade specializing in <%= subjects.slice(0, 3).join(', ') %>. Rating: <%= rating.toFixed(1) %>. Book a session today.">
  <link rel="canonical" href="https://studyglade.com/tutor/<%= tutor._id %>">
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/index.css">
  <style>
    .profile-container { max-width: 1000px; margin: 2rem auto; background: white; border-radius: 32px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
    .profile-header { display: flex; gap: 2rem; align-items: center; flex-wrap: wrap; margin-bottom: 2rem; border-bottom: 1px solid #eef2f6; padding-bottom: 1.5rem; }
    .profile-avatar { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid var(--brand-blue); }
    .profile-info h1 { font-size: 2rem; margin-bottom: 0.25rem; }
    .rating i { color: var(--warning); margin-right: 0.2rem; }
    .subjects-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1rem 0; }
    .subject-tag { background: var(--pale-blue); padding: 0.3rem 1rem; border-radius: 40px; font-size: 0.8rem; }
    .bio { margin: 1rem 0; line-height: 1.6; color: var(--slate); }
    .stats { display: flex; gap: 2rem; margin: 1rem 0; flex-wrap: wrap; }
    .stat { background: #f8fafc; padding: 0.5rem 1rem; border-radius: 40px; }
    .section-title { font-size: 1.4rem; margin: 1.5rem 0 1rem; }
    .questions-list, .documents-list { list-style: none; padding: 0; }
    .questions-list li, .documents-list li { margin-bottom: 0.5rem; }
    .questions-list a, .documents-list a { text-decoration: none; color: var(--text-navy); display: flex; justify-content: space-between; align-items: center; padding: 0.5rem; border-bottom: 1px solid #eef2f6; }
    .questions-list a:hover, .documents-list a:hover { color: var(--brand-blue); }
    .price { font-weight: 600; color: var(--brand-blue); }
    .btn-primary-sm { display: inline-block; background: var(--brand-blue); color: white; padding: 0.5rem 1.2rem; border-radius: 40px; text-decoration: none; margin-top: 0.5rem; transition: 0.2s; }
    .btn-primary-sm:hover { background: #004ecc; transform: translateY(-2px); }
  </style>
</head>
<body>
  <header>
    <nav class="navbar"><!-- same navbar as homepage --></nav>
  </header>
  <main>
    <div class="container profile-container">
      <div class="profile-header">
        <img class="profile-avatar" src="<%= tutor.avatar || 'https://randomuser.me/api/portraits/lego/1.jpg' %>" alt="<%= tutor.fullName %>">
        <div class="profile-info">
          <h1><%= tutor.fullName %></h1>
          <div class="rating">
            <i class="fas fa-star"></i> <strong><%= rating.toFixed(1) %></strong> (<%= completedCount %> lessons completed)
          </div>
          <div class="subjects-list">
            <% subjects.forEach(s => { %>
              <span class="subject-tag"><%= s %></span>
            <% }) %>
          </div>
          <div class="bio"><%= tutor.tutorProfile?.bio || `${tutor.fullName} is a dedicated tutor passionate about helping students excel.` %></div>
          <div class="stats">
            <div class="stat"><i class="fas fa-dollar-sign"></i> <%= totalEarnings.toFixed(2) %> earned</div>
            <div class="stat"><i class="fas fa-check-circle"></i> Verified Tutor</div>
          </div>
          <a href="/post-question.html?tutor=<%= tutor._id %>" class="btn-primary-sm">Request Tutoring</a>
        </div>
      </div>

      <h2 class="section-title">Recent Completed Questions</h2>
      <% if (questions.length) { %>
        <ul class="questions-list">
          <% questions.forEach(q => { %>
            <li><a href="/question/<%= q._id %>"><%= q.title %> <i class="fas fa-arrow-right"></i></a></li>
          <% }) %>
        </ul>
      <% } else { %>
        <p>No answered questions yet. Be the first to request help from this tutor.</p>
      <% } %>

      <h2 class="section-title">Study Materials Uploaded by <%= tutor.fullName %></h2>
      <% if (documents.length) { %>
        <ul class="documents-list">
          <% documents.forEach(d => { %>
            <li><a href="/document/<%= d.slug %>"><%= d.title %> <span class="price">$<%= d.price %></span> <i class="fas fa-arrow-right"></i></a></li>
          <% }) %>
        </ul>
      <% } else { %>
        <p>No documents uploaded yet.</p>
      <% } %>
    </div>
  </main>
  <footer class="premium-footer">
  <div class="footer-container">
    <div class="footer-brand">
      <div class="footer-logo-wrapper"><a href="/" class="footer-logo">StudyGlade<i class="fas fa-pen-fancy"></i></a></div>
      <p class="brand-description">Empowering students worldwide with expert academic help, quality resources, and a supportive learning community.</p>
      <div class="newsletter-box"><h5>Stay Updated</h5><form class="newsletter-form"><input type="email" placeholder="Enter your email" required><button type="submit">Join</button></form><p class="newsletter-note">Join 10k+ students. No spam, ever.</p></div>
      <div class="social-links"><a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a><a href="#" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a><a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a><a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a><a href="#" aria-label="TikTok"><i class="fab fa-tiktok"></i></a><a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a></div>
    </div>
    <div class="footer-links-grid">
      <div class="link-column"><h4>Platform</h4><ul><li><a href="/post-question">Post a Question</a></li><li><a href="/document-library.html">Browse Documents</a></li><li><a href="/find-tutors">Find a Tutor</a></li><li><a href="/online-classroom">Online Classroom</a></li><li><a href="/study-library">Study Library</a></li><li><a href="/calendar">Calendar</a></li></ul></div>
      <div class="link-column"><h4>Resources</h4><ul>
        <li><a href="/study-materials">Study Materials</a></li>
        <li><a href="/research-papers">Research Papers</a></li>
        <li><a href="/practice-tests">Practice Tests</a></li>
        <li><a href="/subject-guides">Subject Guides</a></li>
        <li><a href="/academic-tools">Academic Tools</a></li>
        <li><a href="/free-resources">Free Resources</a></li>
        <li><a href="/questions"><strong>All Solved Questions</strong></a></li>
        <li><a href="/subjects"><strong>All Subjects</strong></a></li>       <!-- ✅ NEW -->
        <li><a href="/tutor/"><strong>All Tutors</strong></a></li>           <!-- ✅ NEW -->
      </ul></div>
      <div class="link-column"><h4>Support</h4><ul><li><a href="/help">Help Centre</a></li><li><a href="/contact">Contact Us</a></li><li><a href="/live-chat">Live Chat</a></li><li><a href="/how-it-works">How It Works</a></li><li><a href="/tutor-support">Tutor Support</a></li><li><a href="/feedback">Feedback</a></li></ul></div>
      <div class="link-column"><h4>Legal</h4><ul><li><a href="/privacy">Privacy Policy</a></li><li><a href="/terms">Terms of Service</a></li><li><a href="/refund">Refund Policy</a></li><li><a href="/cookies">Cookie Policy</a></li><li><a href="/honor-code">Honor Code</a></li></ul></div>
      <div class="link-column"><h4>About Us</h4><ul><li><a href="/about">About StudyGlade</a></li><li><a href="/careers">Careers</a></li><li><a href="/press">Press & Media</a></li><li><a href="/blog">Blog</a></li><li><a href="/partnerships">Partnerships</a></li></ul></div>
    </div>
  </div>
  <div class="footer-bottom"><p>© <span id="year"></span> StudyGlade. All rights reserved.</p><button class="back-to-top" id="backToTopBtn"><i class="fas fa-arrow-up"></i> Top</button></div>
</footer>
</body>
</html>