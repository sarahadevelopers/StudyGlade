<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= tutor.fullName %> – Expert Tutor | StudyGlade</title>
  <meta name="description" content="<%= tutor.fullName %> is a verified tutor on StudyGlade specializing in <%= subjects.slice(0, 3).join(', ') %>. Rating: <%= rating.toFixed(1) %>. Book a session today.">
  <meta name="keywords" content="<%= subjects.join(', ') %>, tutor, online tutoring, <%= tutor.fullName %>, homework help">
  <link rel="canonical" href="https://studyglade.com/tutor/<%= tutor._id %>">
  <meta property="og:title" content="<%= tutor.fullName %> – Expert Tutor | StudyGlade">
  <meta property="og:description" content="<%= tutor.fullName %> specializes in <%= subjects.slice(0, 3).join(', ') %>. Rating: <%= rating.toFixed(1) %>. Book a session.">
  <meta property="og:image" content="<%= tutor.avatar || 'https://studyglade.com/default-avatar.png' %>">
  <meta property="og:url" content="https://studyglade.com/tutor/<%= tutor._id %>">
  <meta property="og:type" content="profile">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" type="image/webp" href="images/studyglade-pen-favicon.webp">
<link rel="icon" type="image/png" href="images/studyglade-pen-favicon.png" sizes="32x32">
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/index.css">
  
  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studyglade.com/" },
      { "@type": "ListItem", "position": 2, "name": "All Tutors", "item": "https://studyglade.com/tutor/" },
      { "@type": "ListItem", "position": 3, "name": "<%= tutor.fullName.replace(/"/g, '\\"') %>", "item": "https://studyglade.com/tutor/<%= tutor._id %>" }
    ]
  }
  </script>
  
  <!-- ProfilePage Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "name": "<%= tutor.fullName.replace(/"/g, '\\"') %>",
    "description": "<%= (tutor.tutorProfile?.bio || 'Experienced tutor').substring(0, 200).replace(/"/g, '\\"') %>",
    "url": "https://studyglade.com/tutor/<%= tutor._id %>",
    "mainEntity": {
      "@type": "Person",
      "name": "<%= tutor.fullName.replace(/"/g, '\\"') %>",
      "image": "<%= tutor.avatar || 'https://studyglade.com/default-avatar.png' %>",
      "knowsAbout": <%= JSON.stringify(subjects) %>,
      "rating": {
        "@type": "Rating",
        "ratingValue": "<%= rating.toFixed(1) %>",
        "bestRating": "5"
      }
    }
  }
  </script>
  
  <style>
    /* Additional styles for consistency */
    .breadcrumb-nav { margin-bottom: 1rem; font-size: 0.8rem; }
    .breadcrumb-nav ul { list-style: none; display: flex; gap: 0.5rem; flex-wrap: wrap; padding: 0; margin: 1rem 0; }
    .breadcrumb-nav li { display: inline-flex; align-items: center; gap: 0.3rem; }
    .breadcrumb-nav li:not(:last-child)::after { content: "›"; color: var(--slate); }
    .breadcrumb-nav a { text-decoration: none; color: var(--brand-blue); }
    .profile-container { max-width: 1000px; margin: 2rem auto; background: white; border-radius: 32px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
    .profile-header { display: flex; gap: 2rem; align-items: center; flex-wrap: wrap; margin-bottom: 2rem; border-bottom: 1px solid #eef2f6; padding-bottom: 1.5rem; }
    .profile-avatar { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid var(--brand-blue); }
    .profile-info h1 { font-size: 2rem; margin-bottom: 0.25rem; }
    .rating i { color: var(--warning); margin-right: 0.2rem; }
    .subjects-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1rem 0; }
    .subject-tag { background: var(--pale-blue); padding: 0.3rem 1rem; border-radius: 40px; font-size: 0.8rem; text-decoration: none; color: var(--brand-blue); display: inline-block; transition: 0.2s; }
    .subject-tag:hover { background: var(--brand-blue); color: white; transform: translateY(-2px); }
    .bio { margin: 1rem 0; line-height: 1.6; color: var(--slate); }
    .stats { display: flex; gap: 2rem; margin: 1rem 0; flex-wrap: wrap; }
    .stat { background: #f8fafc; padding: 0.5rem 1rem; border-radius: 40px; }
    .section-title { font-size: 1.4rem; margin: 1.5rem 0 1rem; }
    .questions-list, .documents-list { list-style: none; padding: 0; }
    .questions-list li, .documents-list li { margin-bottom: 0.5rem; }
    .questions-list a, .documents-list a { text-decoration: none; color: var(--text-navy); display: flex; justify-content: space-between; align-items: center; padding: 0.5rem; border-bottom: 1px solid #eef2f6; }
    .questions-list a:hover, .documents-list a:hover { color: var(--brand-blue); }
    .price { font-weight: 600; color: var(--brand-blue); }
    .btn-primary-sm { display: inline-block; background: var(--brand-blue); color: white; padding: 0.5rem 1.2rem; border-radius: 40px; text-decoration: none; margin-top: 0.5rem; transition: 0.2s; }
    .btn-primary-sm:hover { background: #004ecc; transform: translateY(-2px); }
  </style>
</head>
<body>

<header>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">StudyGlade<i class="fas fa-pen-fancy"></i></a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/document-library.html">Library</a>
        <a href="/subjects">Subjects</a>
        <a href="/pricing">Pricing</a>
      </div>
      <div class="nav-buttons">
        <a href="/login.html" class="btn btn-outline-white">Login</a>
        <a href="/register.html" class="btn btn-primary">Sign Up</a>
      </div>
    </div>
  </nav>
</header>

<main>
  <div class="container">
    <!-- Breadcrumb UI -->
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/tutor/">All Tutors</a></li>
        <li><span><%= tutor.fullName %></span></li>
      </ul>
    </nav>

    <div class="profile-container">
      <div class="profile-header">
        <img class="profile-avatar" src="<%= tutor.avatar || 'https://randomuser.me/api/portraits/lego/1.jpg' %>" alt="<%= tutor.fullName %>">
        <div class="profile-info">
          <h1><%= tutor.fullName %></h1>
          <div class="rating">
            <i class="fas fa-star"></i> <strong><%= rating.toFixed(1) %></strong> (<%= completedCount %> lessons completed)
          </div>
          <div class="subjects-list">
            <% subjects.forEach(s => { %>
              <a href="/subjects/<%= s.toLowerCase().replace(/ /g, '-') %>" class="subject-tag"><%= s %></a>
            <% }) %>
          </div>
          <div class="bio"><%= tutor.tutorProfile?.bio || `${tutor.fullName} is a dedicated tutor passionate about helping students excel.` %></div>
          <div class="stats">
            <div class="stat"><i class="fas fa-dollar-sign"></i> <%= totalEarnings.toFixed(2) %> earned</div>
            <div class="stat"><i class="fas fa-check-circle"></i> Verified Tutor</div>
          </div>
          <a href="/post-question.html?tutor=<%= tutor._id %>" class="btn-primary-sm">Request Tutoring</a>
        </div>
      </div>

      <h2 class="section-title">Recent Completed Questions</h2>
      <% if (questions.length) { %>
        <ul class="questions-list">
          <% questions.forEach(q => { %>
            <li><a href="/question/<%= q._id %>"><%= q.title %> <i class="fas fa-arrow-right"></i></a></li>
          <% }) %>
        </ul>
        <p><a href="/questions?tutor=<%= tutor._id %>">See all questions answered by <%= tutor.fullName %></a></p>
      <% } else { %>
        <p>No answered questions yet. Be the first to request help from this tutor.</p>
      <% } %>

      <h2 class="section-title">Study Materials Uploaded by <%= tutor.fullName %></h2>
      <% if (documents.length) { %>
        <ul class="documents-list">
          <% documents.forEach(d => { %>
            <li><a href="/document/<%= d.slug %>"><%= d.title %> <span class="price">$<%= d.price %></span> <i class="fas fa-arrow-right"></i></a></li>
          <% }) %>
        </ul>
      <% } else { %>
        <p>No documents uploaded yet.</p>
      <% } %>
    </div>
  </div>
</main>

<footer class="premium-footer">
  <div class="footer-container">
    <div class="footer-brand">
      <div class="footer-logo-wrapper"><a href="/" class="footer-logo">StudyGlade<i class="fas fa-pen-fancy"></i></a></div>
      <p class="brand-description">Empowering students worldwide with expert academic help, quality resources, and a supportive learning community.</p>
      <div class="newsletter-box"><h5>Stay Updated</h5><form class="newsletter-form"><input type="email" placeholder="Enter your email" required><button type="submit">Join</button></form><p class="newsletter-note">Join 10k+ students. No spam, ever.</p></div>
      <div class="social-links"><a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
</a><a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a><a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a><a href="#" aria-label="TikTok"><i class="fab fa-tiktok"></i></a><a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a></div>
    </div>
    <div class="footer-links-grid">
      <div class="link-column"><h4>Platform</h4><ul><li><a href="index.html">Post a Question</a></li><li><a href="document-library.html">Browse Documents</a></li><li><a href="tutor-dashboard.html">Find a Tutor</a></li><li><a href="student-dashboard.html">Online Classroom</a></li><li><a href="document-library.html">Study Library</a></li><li><a href="index.html">Calendar</a></li></ul></div>
      <div class="link-column"><h4>Resources</h4><ul>
        <li><a href="document-library.html">Study Materials</a></li>
        <li><a href="document-library.html">Research Papers</a></li>
        <li><a href="document-library.html">Practice Tests</a></li>
        <li><a href="document-library.html">Subject Guides</a></li>
        <li><a href="document-library.html">Academic Tools</a></li>
        <li><a href="document-library.html">Free Resources</a></li>
        <li><a href="document-library.html"><strong>All Solved Questions</strong></a></li>
        <li><a href="document-library.html"><strong>All Subjects</strong></a></li>       <!-- ✅ NEW -->
        <li><a href="tutor-dashboard.html"><strong>All Tutors</strong></a></li>           <!-- ✅ NEW -->
      </ul></div>
      <div class="link-column"><h4>Support</h4><ul><li><a href="terms.html">Help Centre</a></li><li><a href="contact.html">Contact Us</a></li><li><a href="terms.html">Live Chat</a></li><li><a href="terms.html">How It Works</a></li><li><a href="terms.html">Tutor Support</a></li><li><a href="terms.html">Feedback</a></li></ul></div>
      <div class="link-column"><h4>Legal</h4><ul><li><a href="privacy.html">Privacy Policy</a></li><li><a href="terms.html">Terms of Service</a></li><li><a href="terms.html">Refund Policy</a></li><li><a href="terms.html">Cookie Policy</a></li><li><a href="terms.html">Honor Code</a></li></ul></div>
      <div class="link-column"><h4>About Us</h4><ul><li><a href="about.html">About StudyGlade</a></li><li><a href="terms.html">Careers</a></li><li><a href="terms.html">Press & Media</a></li><li><a href="blog.html">Blog</a></li><li><a href="terms.html">Partnerships</a></li></ul></div>
    </div>
  </div>
  <div class="footer-bottom">
  <p>© 2015 – <span id="currentYear"></span> StudyGlade. All rights reserved.</p>
  <button class="back-to-top" id="backToTopBtn" style="background-color: #38BDF8; color: aliceblue;">
    <i class="fas fa-arrow-up"></i> Top
  </button>
</div>
</footer>

<script>
   // Dynamic copyright year (2015 - current)
const yearSpan = document.getElementById('currentYear');
if (yearSpan) {
  yearSpan.textContent = new Date().getFullYear();
}
  const backToTopBtn = document.getElementById('backToTopBtn');
  if (backToTopBtn) backToTopBtn.addEventListener('click', (e) => { e.preventDefault(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
</script>
</body>
</html>