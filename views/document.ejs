<script>
  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, m => m === '&' ? '&amp;' : m === '<' ? '&lt;' : '&gt;');
  }

  // Smart Preview logic
  document.addEventListener('DOMContentLoaded', function() {
    const smartBtn = document.getElementById('smartPreviewBtn');
    const smartQuery = document.getElementById('smartQuery');
    const smartResult = document.getElementById('smartPreviewResult');
    let debounceTimer;

    if (smartQuery) {
      smartQuery.addEventListener('input', function() {
        if (smartResult && smartResult.style.display === 'block') {
          smartResult.style.display = 'none';
          smartResult.innerHTML = '';
        }
      });
      smartQuery.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          if (smartBtn) smartBtn.click();
        }
      });
    }

    if (smartBtn && smartQuery && smartResult) {
      smartBtn.addEventListener('click', async function() {
        const query = smartQuery.value.trim();
        if (!query) {
          smartResult.style.display = 'block';
          smartResult.innerHTML = '<span style="color:#f59e0b;">Please enter a question first.</span>';
          return;
        }

        if (debounceTimer) clearTimeout(debounceTimer);
        debounceTimer = setTimeout(async () => {
          smartResult.style.display = 'block';
          smartResult.innerHTML = '<span class="spinner"></span> Searching document...';
          smartBtn.disabled = true;

          try {
            const response = await fetch(`/api/documents/smart-preview/<%= document._id %>`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ query: query })
            });
            const data = await response.json();

            if (response.ok && data.snippet) {
              if (data.snippet.includes('No readable preview')) {
                smartResult.innerHTML = `<span style="color:#f59e0b;">${escapeHtml(data.snippet)}</span>`;
              } else {
                smartResult.innerHTML = `<strong>🔍 Relevant section:</strong><br>${escapeHtml(data.snippet)}`;
              }
            } else {
              smartResult.innerHTML = `<span style="color:#dc2626;">${escapeHtml(data.error) || 'No matching content found. Try a different question.'}</span>`;
            }
          } catch (err) {
            console.error('Smart preview error:', err);
            smartResult.innerHTML = '<span style="color:#dc2626;">Network error. Please try again.</span>';
          } finally {
            smartBtn.disabled = false;
          }
        }, 300);
      });
    }
  });

  // Dynamic copyright year
  const yearSpan = document.getElementById('currentYear');
  if (yearSpan) yearSpan.textContent = new Date().getFullYear();
</script>

<% if (user) { %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const unlockBtn = document.getElementById('unlockBtn');
    const messageBox = document.getElementById('message');
    const previewUnlockBtn = document.getElementById('unlockFromPreviewBtn');

    async function refreshUser() {
      try {
        const response = await fetch('/api/auth/me', { credentials: 'include' });
        if (response.ok) {
          const userData = await response.json();
          localStorage.setItem('user', JSON.stringify(userData));
          return userData;
        }
      } catch (err) {
        console.error('Failed to refresh user:', err);
      }
      return null;
    }

    async function handleUnlock() {
      if (!unlockBtn) return;
      unlockBtn.disabled = true;
      unlockBtn.innerText = 'Processing...';
      
      try {
        const response = await fetch(`/api/documents/<%= document._id %>/unlock`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        
        if (response.ok) {
          messageBox.innerHTML = `<span style="color:#059669;">✓ Unlocked! <a href="<%= document.fileUrl %>" target="_blank" style="color:#2563eb;">Download now</a></span>`;
          if (unlockBtn) unlockBtn.style.display = 'none';
          if (previewUnlockBtn) previewUnlockBtn.style.display = 'none';
        } else {
          messageBox.innerHTML = `<span style="color:#dc2626;">${data.error || 'Insufficient balance.'} <a href="/student-dashboard.html?returnTo=${encodeURIComponent(window.location.pathname)}" style="color:#2563eb;">Add funds now</a></span>`;
          unlockBtn.disabled = false;
          unlockBtn.innerText = 'Unlock';
        }
      } catch (err) {
        console.error('Unlock error:', err);
        messageBox.innerHTML = '<span style="color:#dc2626;">Network error. Try again.</span>';
        unlockBtn.disabled = false;
        unlockBtn.innerText = 'Unlock';
      }
    }

    if (unlockBtn) unlockBtn.addEventListener('click', handleUnlock);
    if (previewUnlockBtn) previewUnlockBtn.addEventListener('click', handleUnlock);
  });
</script>
<% } %>
