<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= document.title %> | StudyGlade</title>
  <meta name="description" content="<%= document.description ? document.description.slice(0, 160) : 'Academic document on ' + document.subject %>">
  <meta property="og:title" content="<%= document.title %>">
  <meta property="og:description" content="<%= document.description ? document.description.slice(0, 160) : 'Academic document on ' + document.subject %>">
  <meta property="og:image" content="<%= document.previewImageUrl %>">
  <meta property="og:type" content="article">
  <link rel="canonical" href="https://studyglade.onrender.com/document/<%= document.slug %>">
  <style>
    body { font-family: system-ui, sans-serif; max-width: 1000px; margin: 0 auto; padding: 20px; background: #f5f5f5; }
    .card { background: white; border-radius: 16px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .preview-img { max-width: 100%; border-radius: 8px; margin: 20px 0; box-shadow: 0 2px 6px rgba(0,0,0,0.1); }
    .btn { display: inline-block; background: #3b82f6; color: white; padding: 12px 24px; border-radius: 40px; text-decoration: none; font-weight: bold; }
    .btn:hover { background: #2563eb; }
    .price { font-size: 24px; font-weight: bold; color: #10b981; }
  </style>
</head>
<body>
  <div class="card">
    <h1><%= document.title %></h1>
    <p><strong>Subject:</strong> <%= document.subject %> | <strong>Level:</strong> <%= document.level %></p>
    <p><%= document.description || '' %></p>

    <% if (document.previewImageUrl) { %>
      <img class="preview-img" src="<%= document.previewImageUrl %>" alt="First page preview">
    <% } %>

    <div class="preview-text">
      <h3>Preview (first 500 characters):</h3>
      <p><%= document.previewText || 'Preview not available.' %></p>
    </div>

    <div class="price">
      Price: $<%= document.price.toFixed(2) %>
    </div>

    <div style="margin-top: 30px;">
      <% if (!user) { %>
        <a href="/register?returnTo=/document/<%= document.slug %>" class="btn">Sign up to unlock full document</a>
        <a href="/login?returnTo=/document/<%= document.slug %>" style="margin-left: 12px;">Already have an account? Log in</a>
      <% } else { %>
        <button id="unlockBtn" class="btn">Unlock for $<%= document.price.toFixed(2) %></button>
        <div id="message" style="margin-top: 16px;"></div>
      <% } %>
    </div>
  </div>

  <% if (user) { %>
  <script>
    document.getElementById('unlockBtn').addEventListener('click', async () => {
      const btn = event.target;
      btn.disabled = true;
      btn.innerText = 'Processing...';
      try {
        const res = await fetch(`/api/documents/<%= document._id %>/unlock`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        if (res.ok) {
          document.getElementById('message').innerHTML = `<span style="color:green;">✓ Unlocked! <a href="<%= document.fileUrl %>" target="_blank">Download now</a></span>`;
        } else {
          document.getElementById('message').innerHTML = `<span style="color:red;">${data.error || 'Unlock failed. Insufficient balance?'}</span>`;
          btn.disabled = false;
          btn.innerText = 'Unlock';
        }
      } catch (err) {
        document.getElementById('message').innerHTML = '<span style="color:red;">Network error. Try again.</span>';
        btn.disabled = false;
        btn.innerText = 'Unlock';
      }
    });
  </script>
  <% } %>
</body>
</html>