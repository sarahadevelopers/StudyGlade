<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= post.title %> | StudyGlade Blog</title>
  <meta name="description" content="<%= post.excerpt || post.content.substring(0, 160).replace(/<[^>]*>/g, '') %>">
  <link rel="canonical" href="https://studyglade.com/blog/<%= post.slug %>">
  <meta property="og:title" content="<%= post.title %>">
  <meta property="og:description" content="<%= post.excerpt || post.content.substring(0, 160).replace(/<[^>]*>/g, '') %>">
  <meta property="og:image" content="<%= post.featuredImage || 'https://studyglade.com/og-logo.png' %>">
  <meta property="og:url" content="https://studyglade.com/blog/<%= post.slug %>">
  <meta property="og:type" content="article">
  <meta name="twitter:card" content="summary_large_image">
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/index.css">
  
  <!-- Article Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "<%= post.title.replace(/"/g, '\\"') %>",
    "description": "<%= (post.excerpt || post.content.substring(0, 160)).replace(/"/g, '\\"').replace(/<[^>]*>/g, '') %>",
    "author": { "@type": "Person", "name": "<%= post.author || 'StudyGlade Team' %>" },
    "datePublished": "<%= post.publishedAt ? new Date(post.publishedAt).toISOString() : new Date().toISOString() %>",
    "dateModified": "<%= post.updatedAt ? new Date(post.updatedAt).toISOString() : new Date().toISOString() %>",
    "mainEntityOfPage": "https://studyglade.com/blog/<%= post.slug %>"
  }
  </script>
  
  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studyglade.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://studyglade.com/blog" },
      { "@type": "ListItem", "position": 3, "name": "<%= post.title.replace(/"/g, '\\"') %>", "item": "https://studyglade.com/blog/<%= post.slug %>" }
    ]
  }
  </script>
  
  <style>
    .blog-post-container { max-width: 800px; margin: 2rem auto; }
    .blog-post-header { margin-bottom: 1.5rem; }
    .blog-post-title { font-size: 2rem; margin-bottom: 0.5rem; }
    .blog-post-meta { color: var(--slate); font-size: 0.85rem; margin-bottom: 1rem; }
    .blog-post-content { font-size: 1.05rem; line-height: 1.7; color: var(--text-navy); }
    .blog-post-content h2 { font-size: 1.5rem; margin: 1.5rem 0 0.5rem; }
    .blog-post-content h3 { font-size: 1.3rem; margin: 1.2rem 0 0.5rem; }
    .blog-post-content p { margin-bottom: 1rem; }
    .blog-post-content ul, .blog-post-content ol { margin: 1rem 0 1rem 2rem; }
    .blog-post-content img { max-width: 100%; border-radius: 16px; margin: 1rem 0; }
    .blog-post-content a { color: var(--brand-blue); text-decoration: underline; }
    .cta-box { background: var(--pale-blue); padding: 1.5rem; border-radius: 24px; text-align: center; margin: 2rem 0; }
    .breadcrumb-nav { margin-bottom: 1rem; font-size: 0.8rem; }
    .breadcrumb-nav ul { list-style: none; display: flex; gap: 0.5rem; flex-wrap: wrap; padding: 0; margin: 1rem 0; }
    .breadcrumb-nav li { display: inline-flex; align-items: center; gap: 0.3rem; }
    .breadcrumb-nav li:not(:last-child)::after { content: "›"; color: var(--slate); }
    .breadcrumb-nav a { text-decoration: none; color: var(--brand-blue); }
  </style>
</head>
<body>
  <header>
    <nav class="navbar">
      <div class="container">
        <a href="/" class="logo">StudyGlade<i class="fas fa-pen-fancy"></i></a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/document-library.html">Library</a>
          <a href="/subjects">Subjects</a>
          <a href="/blog" class="active">Blog</a>
          <a href="/pricing">Pricing</a>
        </div>
        <div class="nav-buttons">
          <a href="/login.html" class="btn btn-outline-white">Login</a>
          <a href="/register.html" class="btn btn-primary">Sign Up</a>
        </div>
      </div>
    </nav>
  </header>

  <main>
    <div class="container">
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><span><%= post.title %></span></li>
        </ul>
      </nav>

      <div class="blog-post-container">
        <div class="blog-post-header">
          <h1 class="blog-post-title"><%= post.title %></h1>
          <div class="blog-post-meta">
            <i class="far fa-calendar-alt"></i> <%= new Date(post.publishedAt).toLocaleDateString() %> &nbsp;|&nbsp;
            <i class="far fa-user"></i> <%= post.author || 'StudyGlade Team' %>
          </div>
        </div>
        <div class="blog-post-content">
          <%- post.content %>
        </div>

        <!-- Call to Action -->
        <div class="cta-box">
          <p>📚 Need help with homework? <a href="/post-question.html">Post your question now</a> and get instant help from expert tutors.</p>
          <p style="margin-top: 0.5rem;">🔍 Explore our <a href="/subjects">subject library</a> or browse <a href="/document-library.html">study documents</a>.</p>
        </div>

        <!-- Optional: Related Posts (you can add if you create a related posts function) -->
        <% if (relatedPosts && relatedPosts.length) { %>
          <h3>Related Articles</h3>
          <ul class="related-list">
            <% relatedPosts.forEach(rel => { %>
              <li><a href="/blog/<%= rel.slug %>"><%= rel.title %></a></li>
            <% }) %>
          </ul>
        <% } %>
      </div>
    </div>
  </main>

  <footer class="premium-footer">
    <div class="footer-container">
      <div class="footer-brand">
        <div class="footer-logo-wrapper"><a href="/" class="footer-logo">StudyGlade<i class="fas fa-pen-fancy"></i></a></div>
        <p class="brand-description">Empowering students worldwide with expert academic help, quality resources, and a supportive learning community.</p>
        <div class="newsletter-box"><h5>Stay Updated</h5><form class="newsletter-form"><input type="email" placeholder="Enter your email" required><button type="submit">Join</button></form><p class="newsletter-note">Join 10k+ students. No spam, ever.</p></div>
        <div class="social-links"><a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a><a href="#" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a><a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a><a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a><a href="#" aria-label="TikTok"><i class="fab fa-tiktok"></i></a><a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a></div>
      </div>
      <div class="footer-links-grid">
        <div class="link-column"><h4>Platform</h4><ul><li><a href="/post-question">Post a Question</a></li><li><a href="/document-library.html">Browse Documents</a></li><li><a href="/find-tutors">Find a Tutor</a></li><li><a href="/online-classroom">Online Classroom</a></li><li><a href="/study-library">Study Library</a></li><li><a href="/calendar">Calendar</a></li></ul></div>
        <div class="link-column"><h4>Resources</h4><ul><li><a href="/study-materials">Study Materials</a></li><li><a href="/research-papers">Research Papers</a></li><li><a href="/practice-tests">Practice Tests</a></li><li><a href="/subject-guides">Subject Guides</a></li><li><a href="/academic-tools">Academic Tools</a></li><li><a href="/free-resources">Free Resources</a></li><li><a href="/questions"><strong>All Solved Questions</strong></a></li><li><a href="/subjects"><strong>All Subjects</strong></a></li><li><a href="/tutor/"><strong>All Tutors</strong></a></li><li><a href="/blog"><strong>Blog</strong></a></li></ul></div>
        <div class="link-column"><h4>Support</h4><ul><li><a href="/help">Help Centre</a></li><li><a href="/contact">Contact Us</a></li><li><a href="/live-chat">Live Chat</a></li><li><a href="/how-it-works">How It Works</a></li><li><a href="/tutor-support">Tutor Support</a></li><li><a href="/feedback">Feedback</a></li></ul></div>
        <div class="link-column"><h4>Legal</h4><ul><li><a href="/privacy">Privacy Policy</a></li><li><a href="/terms">Terms of Service</a></li><li><a href="/refund">Refund Policy</a></li><li><a href="/cookies">Cookie Policy</a></li><li><a href="/honor-code">Honor Code</a></li></ul></div>
        <div class="link-column"><h4>About Us</h4><ul><li><a href="/about">About StudyGlade</a></li><li><a href="/careers">Careers</a></li><li><a href="/press">Press & Media</a></li><li><a href="/blog">Blog</a></li><li><a href="/partnerships">Partnerships</a></li></ul></div>
      </div>
    </div>
    <div class="footer-bottom"><p>© <span id="year"></span> StudyGlade. All rights reserved.</p><button class="back-to-top" id="backToTopBtn"><i class="fas fa-arrow-up"></i> Top</button></div>
  </footer>
  <script>
    document.getElementById('year').textContent = new Date().getFullYear();
    const backToTopBtn = document.getElementById('backToTopBtn');
    if (backToTopBtn) backToTopBtn.addEventListener('click', (e) => { e.preventDefault(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
  </script>
</body>
</html>